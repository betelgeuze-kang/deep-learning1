            "candidate_promotion_blocked",
            "hash_clean_wrong_span_block",
            "corrupted_route_index_block",
            "corrupted_chunk_offsets_block",
            "raw_input_shortcut_block",
            "input_extractor_promotion_block",
            "oracle_promotion_block",
            "block_reason",
        ],
        rows,
    )
    summary = {
        "negative_scope": "v14-b-lite-shortcut-negative-suite",
        "negative_case_rows": len(rows),
        "candidate_promotion_blocked_rows": sum(int(row["candidate_promotion_blocked"]) for row in rows),
        "hash_clean_wrong_span_block": max(int(row["hash_clean_wrong_span_block"]) for row in rows),
