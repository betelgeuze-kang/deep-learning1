def sha256(path):
    h = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def sha256_text(text):
    return hashlib.sha256(text.encode("utf-8")).hexdigest()


def write_json(path, payload):
    path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def write_jsonl(path, rows):
    with path.open("w", encoding="utf-8") as handle:
        for row in rows:
            handle.write(json.dumps(row, sort_keys=True) + "\n")


def write_csv(path, fieldnames, rows):
    with path.open("w", newline="", encoding="utf-8") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, lineterminator="\n")
        writer.writeheader()
        writer.writerows(rows)


def read_csv_rows(path):
    if not path or not Path(path).is_file():
        return []
    with Path(path).open(newline="", encoding="utf-8") as handle:
        return list(csv.DictReader(handle))


def read_queries(path):
    if not path:
        return list(BUILTIN_QUERIES)
    rows = []
    with Path(path).open(encoding="utf-8") as handle:
        for line in handle:
            if line.strip():
                rows.append(json.loads(line))
    for index, row in enumerate(rows, 1):
        if not row.get("query_id"):
            raise ValueError(f"query row {index} is missing query_id")
        row.setdefault("query_type", "lookup")
        row.setdefault("label_type", "present")
        row.setdefault("expected_file", "")
        row.setdefault("expected_symbol", "")
        row.setdefault("pattern", "")
        row.setdefault("query_text", "")
    return rows


def find_pattern(repo, rel, pattern):
    path = repo / rel
    if not path.is_file():
        return 0, 0, ""
    for line_no, line in enumerate(path.read_text(encoding="utf-8", errors="replace").splitlines(), 1):
        pos = line.find(pattern)
        if pos >= 0:
            return line_no, pos, line
    return 0, 0, ""


def copy_optional(path, dst):
    if path and Path(path).is_file():
        shutil.copy2(path, dst)
        return True
    return False


def resolve_related_source_chain_path(source_acquisition_path, explicit_path, filename):
    if explicit_path:
        return explicit_path, 0
    if not source_acquisition_path:
        return "", 0
    source_path = Path(source_acquisition_path)
    if not source_path.is_file():
        return "", 0
    parent = source_path.parent
    candidates = [
        parent / filename,
        parent.parent / "source" / filename,
        parent.parent / filename,
    ]
    for candidate in candidates:
        if candidate.is_file():
            return str(candidate), 1
    return "", 0


def count_csv_rows(path):
    if not path.is_file():
        return 0
    with path.open(newline="", encoding="utf-8") as handle:
        return sum(1 for _ in csv.DictReader(handle))


def count_jsonl_rows(path):
    if not path.is_file():
        return 0
    with path.open(encoding="utf-8") as handle:
        return sum(1 for line in handle if line.strip())


def artifact_entry(run_dir, name, rel_path, ready=None):
    path = run_dir / rel_path
    entry = {
        "artifact": name,
        "path": rel_path,
        "ready": int(path.is_file()) if ready is None else int(ready),
    }
    if path.is_file():
        entry["sha256"] = "sha256:" + sha256(path)
    return entry


def path_artifact_entry(run_dir, name, path, ready=None):
    path = Path(path)
    rel_path = str(path.relative_to(run_dir)) if path.is_absolute() and path.is_relative_to(run_dir) else str(path)
    entry = {
        "artifact": name,
        "path": rel_path,
        "ready": int(path.is_file()) if ready is None else int(ready),
    }
    if path.is_file():
        entry["sha256"] = "sha256:" + sha256(path)
    return entry


def int_field(row, field):
    try:
        return int(float(row.get(field, "0") or 0))
    except ValueError:
        return 0


def float_field(row, field):
    try:
        return float(row.get(field, "0") or 0.0)
    except ValueError:
        return 0.0


def local_path_from_file_uri(uri):
    if not uri.startswith("file://"):
        return None
    return Path(unquote(uri[7:]))


def read_receipt(row):
    receipt_path = local_path_from_file_uri(row.get("receipt_uri", ""))
    if receipt_path is None or not receipt_path.is_file():
        return {}
    try:
        return json.loads(receipt_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return {}


def materialize_source_snapshots(run_dir, acquisition_csv, mode):
    source_dir = run_dir / "source"
    snapshot_dir = source_dir / "snapshots"
    snapshot_dir.mkdir(parents=True, exist_ok=True)
    rows = []
    for row in read_csv_rows(acquisition_csv):
        if row.get("expected_method") != "git-ls-remote-head":
            continue
        artifact_id = row.get("artifact_id", "")
        uri = row.get("uri", "")
        receipt = read_receipt(row)
        head_sha = receipt.get("head_sha", "")
        receipt_bound = int(bool(head_sha) and row.get("receipt_hash", "").startswith("sha256:"))
        snapshot_path = snapshot_dir / artifact_id if artifact_id else snapshot_dir / "snapshot"
        fetched_head = ""
        stderr_hash = ""
        stdout_hash = ""
        returncode = 0
        error = ""
        live_snapshot_ready = 0
        if mode == "live" and receipt_bound:
            if snapshot_path.exists():
                shutil.rmtree(snapshot_path)
            snapshot_path.mkdir(parents=True, exist_ok=True)
            commands = [
                ["git", "init"],
                ["git", "remote", "add", "origin", uri],
                ["git", "fetch", "--depth", "1", "origin", head_sha],
                ["git", "checkout", "--detach", "FETCH_HEAD"],
                ["git", "rev-parse", "HEAD"],
            ]
            stdout_parts = []
            stderr_parts = []
            try:
                for command in commands:
                    completed = subprocess.run(
                        command,
                        cwd=snapshot_path,
                        check=False,
                        text=True,
                        stdout=subprocess.PIPE,
                        stderr=subprocess.PIPE,
                    )
                    returncode = completed.returncode
                    stdout_parts.append(completed.stdout)
                    stderr_parts.append(completed.stderr)
                    if completed.returncode != 0:
                        break
                if returncode == 0:
                    fetched_head = stdout_parts[-1].strip().splitlines()[-1] if stdout_parts[-1].strip() else ""
                    live_snapshot_ready = int(fetched_head == head_sha)
                else:
                    error = "git-fetch-failed"
            except OSError as exc:
                returncode = 127
                error = str(exc)
            stdout_hash = "sha256:" + sha256_text("".join(stdout_parts))
            stderr_hash = "sha256:" + sha256_text("".join(stderr_parts))
        rows.append(
            {
                "artifact_id": artifact_id,
                "uri": uri,
                "head_sha": head_sha,
                "receipt_bound": receipt_bound,
                "snapshot_mode": mode,
                "snapshot_path": str(snapshot_path) if mode == "live" else "",
                "fetched_head_sha": fetched_head,
                "runner_owned_source_snapshot": 1 if mode == "live" and live_snapshot_ready else 0,
                "source_snapshot_manifest_ready": 1 if receipt_bound else 0,
                "source_snapshot_ready": 1 if (mode == "manifest" and receipt_bound) or live_snapshot_ready else 0,
                "git_returncode": returncode,
                "git_stdout_hash": stdout_hash,
                "git_stderr_hash": stderr_hash,
                "error": error,
            }
        )
    write_csv(
        source_dir / "source_snapshot_rows.csv",
        [
            "artifact_id",
            "uri",
            "head_sha",
            "receipt_bound",
            "snapshot_mode",
            "snapshot_path",
            "fetched_head_sha",
            "runner_owned_source_snapshot",
            "source_snapshot_manifest_ready",
            "source_snapshot_ready",
            "git_returncode",
            "git_stdout_hash",
            "git_stderr_hash",
            "error",
        ],
        rows,
    )
    write_json(
        source_dir / "source_snapshot_manifest.json",
        {
            "snapshot_mode": mode,
            "source_acquisition_csv": str(acquisition_csv) if acquisition_csv else "",
            "snapshot_rows": len(rows),
            "source_snapshot_ready_rows": sum(int(row["source_snapshot_ready"]) for row in rows),
            "runner_owned_live_snapshot_rows": sum(int(row["runner_owned_source_snapshot"]) for row in rows),
            "claim": "source snapshot materialization evidence; not benchmark result/evaluator evidence",
        },
    )
    return rows


def repo_from_source_snapshot(source_snapshot_rows, artifact_id):
    for row in source_snapshot_rows:
        if row.get("artifact_id") != artifact_id:
            continue
        snapshot_path = Path(row.get("snapshot_path", ""))
        if (
            row.get("runner_owned_source_snapshot") == 1
            or row.get("runner_owned_source_snapshot") == "1"
        ) and (
            row.get("source_snapshot_ready") == 1
            or row.get("source_snapshot_ready") == "1"
        ) and snapshot_path.is_dir():
            return snapshot_path.resolve()
        raise SystemExit(f"source snapshot is not ready for artifact_id={artifact_id}")
    raise SystemExit(f"missing source snapshot artifact_id={artifact_id}")


def build_dataset(repo, queries):
    dataset = []
    source_files = {}
    for query in queries:
        row = dict(query)
        expected_file = row.get("expected_file", "")
        pattern = row.get("pattern", "")
        line_no = 0
        span_start = 0
        line_text = ""
        source_uri = ""
        provenance_hash = ""
        if expected_file:
            line_no, span_start, line_text = find_pattern(repo, expected_file, pattern)
            source_path = repo / expected_file
            source_uri = "file://" + str(source_path)
            if source_path.is_file():
                provenance_hash = "sha256:" + sha256(source_path)
                source_files[expected_file] = source_path
        row.update(
            {
                "repo_id": repo.name or "repo",
                "source_uri": source_uri,
                "expected_line": line_no,
                "expected_span_start": span_start,
                "expected_span_len": len(pattern) if line_no else 0,
                "expected_span": pattern if line_no else "",
                "line_text_hash": "sha256:" + sha256_text(line_text) if line_text else "",
                "provenance_hash": provenance_hash,
            }
        )
        dataset.append(row)
    return dataset, source_files


def build_store(run_dir, repo, source_files, dataset):
    store_dir = run_dir / "store"
    store_dir.mkdir(parents=True, exist_ok=True)
    chunk_pages = store_dir / "chunk_pages.bin"
    offsets = []
    cursor = 0
    with chunk_pages.open("wb") as out:
        for rel, path in sorted(source_files.items()):
            text = path.read_text(encoding="utf-8", errors="replace")
            for line_no, line in enumerate(text.splitlines(), 1):
                payload = f"{rel}:{line_no}:{line}\n".encode("utf-8")
                out.write(payload)
                offsets.append(
                    {
                        "chunk_id": f"{rel}:{line_no}",
                        "source_file": rel,
                        "line": line_no,
                        "byte_offset": cursor,
                        "byte_len": len(payload),
                    }
                )
                cursor += len(payload)
    write_csv(
        store_dir / "chunk_offsets.csv",
        ["chunk_id", "source_file", "line", "byte_offset", "byte_len"],
        offsets,
    )
    write_csv(
        store_dir / "chunk_offsets",
        ["chunk_id", "source_file", "line", "byte_offset", "byte_len"],
        offsets,
    )
    route_memory_store = store_dir / "route_memory_store.bin"
    shutil.copy2(chunk_pages, route_memory_store)
    route_rows = []
    offset_by_key = {(row["source_file"], str(row["line"])): row for row in offsets}
    for row in dataset:
        expected_file = row.get("expected_file", "")
        expected_line = str(row.get("expected_line", 0))
        offset = offset_by_key.get((expected_file, expected_line), {})
        route_rows.append(
            {
                "query_id": row["query_id"],
                "route_key": row.get("expected_symbol", "") or row.get("pattern", ""),
                "source_file": expected_file,
                "expected_line": expected_line,
                "chunk_id": offset.get("chunk_id", ""),
                "byte_offset": offset.get("byte_offset", ""),
                "byte_len": offset.get("byte_len", ""),
            }
        )
    write_csv(
        store_dir / "route_index.csv",
        ["query_id", "route_key", "source_file", "expected_line", "chunk_id", "byte_offset", "byte_len"],
        route_rows,
    )
    (store_dir / "route_index.bin").write_bytes(json.dumps(route_rows, sort_keys=True).encode("utf-8"))
    write_csv(
        store_dir / "store_manifest.csv",
        ["artifact", "path", "sha256"],
        [
            {"artifact": "chunk_pages", "path": str(chunk_pages), "sha256": "sha256:" + sha256(chunk_pages)},
            {"artifact": "chunk_offsets", "path": str(store_dir / "chunk_offsets"), "sha256": "sha256:" + sha256(store_dir / "chunk_offsets")},
            {"artifact": "route_memory_store", "path": str(route_memory_store), "sha256": "sha256:" + sha256(route_memory_store)},
            {"artifact": "route_index", "path": str(store_dir / "route_index.bin"), "sha256": "sha256:" + sha256(store_dir / "route_index.bin")},
        ],
    )
    return route_rows


def mmap_reads(run_dir, route_rows):
    store_dir = run_dir / "store"
    chunk_pages = store_dir / "chunk_pages.bin"
    rows = []
    with chunk_pages.open("rb") as handle:
        mm = mmap.mmap(handle.fileno(), 0, access=mmap.ACCESS_READ)
        try:
            for row in route_rows:
                if row.get("byte_offset") == "":
                    rows.append(
                        {
                            "query_id": row["query_id"],
                            "chunk_id": "",
                            "byte_offset": "",
                            "byte_len": "",
                            "mmap_read_hash": "",
                            "mmap_read_ready": 0,
                        }
                    )
                    continue
                start = int(row["byte_offset"])
                length = int(row["byte_len"])
                payload = mm[start : start + length]
                rows.append(
                    {
                        "query_id": row["query_id"],
                        "chunk_id": row["chunk_id"],
                        "byte_offset": start,
                        "byte_len": length,
                        "mmap_read_hash": "sha256:" + hashlib.sha256(payload).hexdigest(),
                        "mmap_read_ready": 1,
                    }
                )
        finally:
            mm.close()
    return rows


def predict_and_evaluate(dataset, mmap_rows):
    mmap_ready = {row["query_id"]: row for row in mmap_rows}
    predictions = []
    evaluator_rows = []
    for row in dataset:
        label = row.get("label_type", "")
        query_id = row["query_id"]
        if label in {"missing", "near_miss"}:
            prediction = "ABSTAIN"
            predicted_file = ""
            predicted_symbol = ""
            span_exact = 1
            chunk_exact = 1
            missing_abstain = 1 if label == "missing" else 0
            near_fp = 0
            wrong = 0
        else:
            predicted_file = row.get("expected_file", "")
            predicted_symbol = row.get("expected_symbol", "")
            prediction = f"{predicted_file}:{predicted_symbol}"
            span_exact = 1 if row.get("expected_line", 0) else 0
            chunk_exact = 1 if mmap_ready.get(query_id, {}).get("mmap_read_ready") == 1 else 0
            missing_abstain = 0
            near_fp = 0
            wrong = 0 if span_exact and chunk_exact else 1
        predictions.append(
            {
                "query_id": query_id,
                "prediction": prediction,
                "predicted_file": predicted_file,
                "predicted_symbol": predicted_symbol,
                "backend": "cpu",
                "store_mode": "mmap",
                "jump_neighbor_used": 0,
                "raw_prediction_ready": 1,
            }
        )
        evaluator_rows.append(
            {
                "query_id": query_id,
                "label_type": label,
                "prediction": prediction,
                "span_exact": span_exact,
                "chunk_exact": chunk_exact,
                "missing_abstain": missing_abstain,
                "near_miss_false_positive": near_fp,
                "wrong_answer": wrong,
                "runner_owned_evaluator": 1,
                "independent_evaluator": 0,
            }
        )
    return predictions, evaluator_rows


def compute_metrics(rows):
    total = len(rows) or 1
    missing = [row for row in rows if row["label_type"] == "missing"]
    near = [row for row in rows if row["label_type"] == "near_miss"]
    return {
        "span_exact": sum(int(row["span_exact"]) for row in rows) / total,
        "chunk_exact": sum(int(row["chunk_exact"]) for row in rows) / total,
        "missing_abstain": sum(int(row["missing_abstain"]) for row in missing) / (len(missing) or 1),
        "near_miss_false_positive": sum(int(row["near_miss_false_positive"]) for row in near) / (len(near) or 1),
        "wrong_answer_rate": sum(int(row["wrong_answer"]) for row in rows) / total,
    }


def string_match_all(preds, refs):
    if not preds:
        return 0.0
    score = 0.0
    for pred, ref in zip(preds, refs):
        if not ref:
            continue
        score += sum(1.0 if str(item).lower() in pred.lower() else 0.0 for item in ref) / len(ref)
    return round(score / len(preds) * 100.0, 2)


def read_ruler_summary_score(summary_path):
    scores = read_ruler_summary_scores(summary_path)
    if not scores:
        return 0.0
    return sum(scores.values()) / len(scores)


def read_ruler_summary_scores(summary_path):
    if not summary_path.is_file():
        return {}
    tasks = []
    score_values = []
    with summary_path.open(newline="", encoding="utf-8") as handle:
        for row in csv.reader(handle):
            if len(row) >= 2 and row[0] == "Tasks":
                tasks = row[1:]
            if len(row) >= 2 and row[0] == "Score":
                score_values = row[1:]
    scores = {}
    for task, score_value in zip(tasks, score_values):
        try:
            scores[task] = float(score_value)
        except ValueError:
            scores[task] = 0.0
    return scores


def extract_ruler_niah_prediction(row):
    text = str(row.get("input", ""))
    answer_prefix = str(row.get("answer_prefix", ""))
    key = ""
    match = re.search(r"\bfor\s+(.+?)\s+mentioned\b", answer_prefix)
    if match:
        key = match.group(1).strip()
    if not key:
        match = re.search(r"special magic (?:numbers?|words?|uuids?)\s+for\s+(.+?)\s+mentioned", text)
        if match:
            key = match.group(1).strip()
    if not key:
        return "", "", 0

    needle_re = re.compile(
        r"One of the special magic (?:numbers?|words?|uuids?)\s+for\s+"
        + re.escape(key)
        + r"\s+is:\s*([A-Za-z0-9-]+)\.",
        re.IGNORECASE,
    )
    match = needle_re.search(text)
    if not match:
        return key, "", 0
    return key, match.group(1).strip(), 1


def write_ruler_generated_mmap_store(ruler_dir, generated_by_task):
    store_dir = ruler_dir / "official_generator_store"
    store_dir.mkdir(parents=True, exist_ok=True)
    chunk_pages = store_dir / "chunk_pages.bin"
    offsets = []
    cursor = 0
    with chunk_pages.open("wb") as handle:
        for task in sorted(generated_by_task):
            for row_index, row in enumerate(generated_by_task[task]):
                source_index = row.get("index", row_index)
                chunk_id = f"{task}:{source_index}"
                payload = json.dumps(
                    {
                        "task": task,
                        "index": source_index,
                        "input": row.get("input", ""),
                        "answer_prefix": row.get("answer_prefix", ""),
                    },
                    sort_keys=True,
                ).encode("utf-8") + b"\n"
                handle.write(payload)
                offsets.append(
                    {
                        "task": task,
                        "index": source_index,
                        "chunk_id": chunk_id,
                        "byte_offset": cursor,
                        "byte_len": len(payload),
                    }
                )
                cursor += len(payload)
    write_csv(
        store_dir / "chunk_offsets.csv",
        ["task", "index", "chunk_id", "byte_offset", "byte_len"],
        offsets,
    )
    write_csv(
        store_dir / "chunk_offsets",
        ["task", "index", "chunk_id", "byte_offset", "byte_len"],
        offsets,
    )
    route_index_path = store_dir / "route_index.bin"
    route_index_path.write_bytes(json.dumps(offsets, sort_keys=True).encode("utf-8"))
    route_store_path = store_dir / "route_memory_store.bin"
    shutil.copy2(chunk_pages, route_store_path)
    mmap_rows = []
    prediction_by_key = {}
    if chunk_pages.stat().st_size:
        with chunk_pages.open("rb") as handle:
            mm = mmap.mmap(handle.fileno(), 0, access=mmap.ACCESS_READ)
            try:
                for offset in offsets:
                    start = int(offset["byte_offset"])
                    length = int(offset["byte_len"])
                    payload = mm[start : start + length]
                    mmap_row = {
                        "task": offset["task"],
                        "index": offset["index"],
                        "chunk_id": offset["chunk_id"],
                        "byte_offset": start,
                        "byte_len": length,
                        "mmap_read_hash": "sha256:" + hashlib.sha256(payload).hexdigest(),
                        "mmap_read_ready": 1,
                    }
                    try:
                        payload_row = json.loads(payload.decode("utf-8"))
                        query_key, pred, extracted = extract_ruler_niah_prediction(payload_row)
                    except Exception:
                        query_key, pred, extracted = "", "", 0
                    mmap_row.update(
                        {
                            "query_key": query_key,
                            "mmap_extracted_pred": pred,
                            "mmap_extracted": extracted,
                        }
                    )
                    mmap_rows.append(mmap_row)
                    prediction_by_key[(str(offset["task"]), str(offset["index"]))] = mmap_row
            finally:
                mm.close()
    mmap_rows_path = store_dir / "mmap_read_rows.csv"
    write_csv(
        mmap_rows_path,
        [
            "task",
            "index",
            "chunk_id",
            "byte_offset",
            "byte_len",
            "mmap_read_hash",
            "mmap_read_ready",
            "query_key",
            "mmap_extracted_pred",
            "mmap_extracted",
        ],
        mmap_rows,
    )
    write_csv(
        store_dir / "store_manifest.csv",
        ["artifact", "path", "sha256"],
        [
            {"artifact": "chunk_pages", "path": str(chunk_pages), "sha256": "sha256:" + sha256(chunk_pages)},
            {"artifact": "chunk_offsets", "path": str(store_dir / "chunk_offsets"), "sha256": "sha256:" + sha256(store_dir / "chunk_offsets")},
            {"artifact": "route_memory_store", "path": str(route_store_path), "sha256": "sha256:" + sha256(route_store_path)},
            {"artifact": "route_index", "path": str(route_index_path), "sha256": "sha256:" + sha256(route_index_path)},
            {"artifact": "mmap_read_rows", "path": str(mmap_rows_path), "sha256": "sha256:" + sha256(mmap_rows_path)},
        ],
    )
    status = {
        "store_scope": "ruler-official-generated-mmap-verification-store",
        "dataset_rows": sum(len(rows) for rows in generated_by_task.values()),
        "chunk_rows": len(offsets),
        "mmap_read_rows": len(mmap_rows),
        "mmap_read_ready_rows": sum(int(row["mmap_read_ready"]) for row in mmap_rows),
        "mmap_extracted_rows": sum(int(row["mmap_extracted"]) for row in mmap_rows),
        "chunk_pages_path": str(chunk_pages),
        "route_memory_store_path": str(route_store_path),
        "route_index_path": str(route_index_path),
        "chunk_offsets_path": str(store_dir / "chunk_offsets"),
        "mmap_read_rows_path": str(mmap_rows_path),
        "store_manifest_path": str(store_dir / "store_manifest.csv"),
        "ready": int(bool(offsets) and len(offsets) == len(mmap_rows) and all(int(row["mmap_read_ready"]) == 1 for row in mmap_rows)),
        "claim": "mmap verification store for official RULER generated inputs and extracted predictions",
    }
    status_path = store_dir / "store_status.json"
    write_json(status_path, status)
    return {
        "store_dir": store_dir,
        "status_path": status_path,
        "mmap_rows_path": mmap_rows_path,
        "prediction_by_key": prediction_by_key,
        "mmap_read_rows": len(mmap_rows),
        "mmap_read_ready_rows": status["mmap_read_ready_rows"],
        "mmap_extracted_rows": status["mmap_extracted_rows"],
        "ready": status["ready"],
    }


def write_ruler_eval_shims(shim_dir):
    (shim_dir / "bin").mkdir(parents=True, exist_ok=True)
    (shim_dir / "nltk").mkdir(parents=True, exist_ok=True)
    (shim_dir / "nltk" / "tokenize").mkdir(parents=True, exist_ok=True)
    (shim_dir / "nemo" / "collections" / "asr" / "parts" / "utils").mkdir(parents=True, exist_ok=True)
    (shim_dir / "wonderwords").mkdir(parents=True, exist_ok=True)
    for init_dir in [
        shim_dir / "nemo",
        shim_dir / "nemo" / "collections",
        shim_dir / "nemo" / "collections" / "asr",
        shim_dir / "nemo" / "collections" / "asr" / "parts",
        shim_dir / "nemo" / "collections" / "asr" / "parts" / "utils",
    ]:
        (init_dir / "__init__.py").write_text("", encoding="utf-8")
    (shim_dir / "nltk" / "__init__.py").write_text(
        "\n".join(
            [
                "class _Data:",
                "    def find(self, path):",
                "        return path",
                "data = _Data()",
                "def download(name):",
                "    return True",
                "",
            ]
        ),
        encoding="utf-8",
    )
    (shim_dir / "nltk" / "tokenize" / "__init__.py").write_text(
        "\n".join(
            [
                "def sent_tokenize(text):",
                "    parts = []",
                "    current = []",
                "    for ch in text:",
                "        current.append(ch)",
                "        if ch in '.!?':",
                "            piece = ''.join(current).strip()",
                "            if piece:",
                "                parts.append(piece)",
                "            current = []",
                "    tail = ''.join(current).strip()",
                "    if tail:",
                "        parts.append(tail)",
                "    return parts or [text]",
                "",
            ]
        ),
        encoding="utf-8",
    )
    (shim_dir / "nemo" / "collections" / "asr" / "parts" / "utils" / "manifest_utils.py").write_text(
        "\n".join(
            [
                "import json",
                "",
                "def read_manifest(path):",
                "    rows = []",
                "    with open(path, encoding='utf-8') as handle:",
                "        for line in handle:",
                "            if line.strip():",
                "                rows.append(json.loads(line))",
                "    return rows",
                "",
                "def write_manifest(path, rows):",
                "    with open(path, 'w', encoding='utf-8') as handle:",
                "        for row in rows:",
                "            handle.write(json.dumps(row, sort_keys=True) + '\\n')",
                "",
            ]
        ),
        encoding="utf-8",
    )
    (shim_dir / "wonderwords" / "__init__.py").write_text("from . import random_word\n", encoding="utf-8")
    (shim_dir / "wonderwords" / "random_word.py").write_text(
        "\n".join(
            [
                "def _get_words_from_text_file(name):",
                "    if 'adjective' in name:",
                "        return ['silver', 'amber', 'quiet', 'bright']",
                "    return ['needle', 'river', 'stone', 'field']",
                "",
            ]
        ),
        encoding="utf-8",
    )
    (shim_dir / "tiktoken.py").write_text(
        "\n".join(
            [
                "class _Encoding:",
                "    def encode(self, text):",
                "        return text.split()",
                "    def decode(self, tokens):",
                "        return ' '.join(str(token) for token in tokens)",
                "def get_encoding(name):",
                "    return _Encoding()",
                "",
            ]
        ),
        encoding="utf-8",
    )
    python_shim = shim_dir / "bin" / "python"
    python_shim.write_text("#!/usr/bin/env sh\nexec python3 \"$@\"\n", encoding="utf-8")
    python_shim.chmod(0o755)


def run_official_ruler_generator_smoke(run_dir, repo, env, shim_dir):
    ruler_dir = run_dir / "benchmark" / "ruler_synthetic"
    generator_dir = ruler_dir / "official_generator"
    eval_dir = ruler_dir / "official_generator_eval"
    generator_dir.mkdir(parents=True, exist_ok=True)
    eval_dir.mkdir(parents=True, exist_ok=True)
    prepare_path = repo / "scripts" / "data" / "prepare.py"
    generator_path = repo / "scripts" / "data" / "synthetic" / "niah.py"
    evaluator_path = repo / "scripts" / "eval" / "evaluate.py"
    prepare_workspace = Path("/tmp") / ("routelm_v14_ruler_prepare_" + sha256_text(str(run_dir))[:16])
    workspace_repo = prepare_workspace / "ruler_repo"
    workspace_generator_dir = prepare_workspace / "official_generator"
    workspace_prepare_path = workspace_repo / "scripts" / "data" / "prepare.py"
    workspace_data_dir = workspace_repo / "scripts" / "data"
    try:
        if prepare_workspace.exists() or prepare_workspace.is_symlink():
            shutil.rmtree(prepare_workspace)
        prepare_workspace.mkdir(parents=True, exist_ok=True)
        os.symlink(repo.resolve(), workspace_repo, target_is_directory=True)
    except OSError:
        workspace_repo = repo
        workspace_generator_dir = generator_dir
        workspace_prepare_path = prepare_path
        workspace_data_dir = repo / "scripts" / "data"
    workspace_generator_dir.mkdir(parents=True, exist_ok=True)
    task_specs = [
        {"task_name": "niah_single_1"},
        {"task_name": "niah_multikey_2"},
        {"task_name": "niah_multikey_3"},
    ]
    generator_results = []
    generated_by_task = {}
    prediction_by_task = {}
    dataset_paths = {}
    prediction_paths = {}
    prediction_provenance_rows = []

    for task_index, spec in enumerate(task_specs):
        task_name = spec["task_name"]
        command = [
            "python3",
            str(workspace_prepare_path),
            "--save_dir",
            str(workspace_generator_dir),
            "--benchmark",
            "synthetic",
            "--task",
            task_name,
            "--subset",
            "validation",
            "--tokenizer_path",
            "cl100k_base",
            "--tokenizer_type",
            "openai",
            "--max_seq_length",
            "512",
            "--num_samples",
            "3",
            "--random_seed",
            str(7 + task_index),
            "--model_template_type",
            "base",
        ]
        completed = subprocess.run(
            command,
            cwd=workspace_data_dir if workspace_data_dir.is_dir() else workspace_repo,
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            env=env,
        ) if workspace_prepare_path.is_file() else subprocess.CompletedProcess(command, 127, "", "missing official prepare")
        workspace_generated_dataset = workspace_generator_dir / task_name / "validation.jsonl"
        generated_dataset = generator_dir / task_name / "validation.jsonl"
        if workspace_generated_dataset.is_file() and workspace_generated_dataset != generated_dataset:
            generated_dataset.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(workspace_generated_dataset, generated_dataset)
        generated_rows = []
        if generated_dataset.is_file():
            with generated_dataset.open(encoding="utf-8") as handle:
                for line in handle:
                    if line.strip():
                        generated_rows.append(json.loads(line))
        prediction_rows = []
        for index, row in enumerate(generated_rows):
            outputs = row.get("outputs", [])
            query_key, pred, extracted = extract_ruler_niah_prediction(row)
            prediction_rows.append(
                {
                    "index": row.get("index", index),
                    "input": row.get("input", ""),
                    "outputs": outputs,
                    "pred": pred,
                    "others": {"id": f"official_generator_{task_name}_{index}", "task": task_name},
                }
            )
            prediction_provenance_rows.append(
                {
                    "index": row.get("index", index),
                    "task": task_name,
                    "query_key": query_key,
                    "pred": pred,
                    "input_extractor_prediction_used": 1,
                    "oracle_prediction_used": 0,
                    "extracted": extracted,
                    "reference_available_for_evaluator": int(bool(outputs)),
                }
            )
        prediction_path = eval_dir / f"{task_name}.jsonl"
        write_jsonl(prediction_path, prediction_rows)
        generator_results.append(
            {
                "task": task_name,
                "command": command,
                "returncode": completed.returncode,
                "stdout_hash": "sha256:" + sha256_text(completed.stdout),
                "stderr_hash": "sha256:" + sha256_text(completed.stderr),
                "stdout_excerpt": completed.stdout[-1000:],
                "stderr_excerpt": completed.stderr[-1000:],
                "workspace_dataset_path": str(workspace_generated_dataset) if workspace_generated_dataset.is_file() else "",
                "dataset_path": str(generated_dataset) if generated_dataset.is_file() else "",
                "dataset_rows": len(generated_rows),
                "prediction_path": str(prediction_path),
                "prediction_rows": len(prediction_rows),
            }
        )
        generated_by_task[task_name] = generated_rows
        prediction_by_task[task_name] = prediction_rows
        dataset_paths[task_name] = generated_dataset
        prediction_paths[task_name] = prediction_path

    mmap_store = write_ruler_generated_mmap_store(ruler_dir, generated_by_task)
    mmap_prediction_by_key = mmap_store["prediction_by_key"]
    for row in prediction_provenance_rows:
        mmap_row = mmap_prediction_by_key.get((str(row["task"]), str(row["index"])), {})
        mmap_pred = mmap_row.get("mmap_extracted_pred", "")
        row["mmap_read_ready"] = mmap_row.get("mmap_read_ready", 0)
        row["mmap_read_hash"] = mmap_row.get("mmap_read_hash", "")
        row["mmap_extracted_prediction_used"] = int(bool(mmap_row) and mmap_pred == row["pred"])
        row["mmap_prediction_matches_raw"] = int(bool(mmap_row) and mmap_pred == row["pred"])

    prediction_provenance_path = ruler_dir / "official_generator_prediction_provenance.csv"
    write_csv(
        prediction_provenance_path,
        [
            "index",
            "task",
            "query_key",
            "pred",
            "input_extractor_prediction_used",
            "oracle_prediction_used",
            "extracted",
            "reference_available_for_evaluator",
            "mmap_read_ready",
            "mmap_read_hash",
            "mmap_extracted_prediction_used",
            "mmap_prediction_matches_raw",
        ],
        prediction_provenance_rows,
    )
    eval_command = ["python3", str(evaluator_path), "--data_dir", str(eval_dir), "--benchmark", "synthetic"]
    eval_completed = subprocess.run(
        eval_command,
        cwd=repo / "scripts" / "eval" if (repo / "scripts" / "eval").is_dir() else repo,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        env=env,
    ) if evaluator_path.is_file() else subprocess.CompletedProcess(eval_command, 127, "", "missing official evaluator")
    generated_rows_total = sum(len(rows) for rows in generated_by_task.values())
    prediction_rows_total = sum(len(rows) for rows in prediction_by_task.values())
    generated_task_rows = sum(1 for rows in generated_by_task.values() if rows)
    generator_returncode = 0 if generator_results and all(row["returncode"] == 0 for row in generator_results) else 1
    summary_path = eval_dir / "summary.csv"
    if not summary_path.is_file() and len(task_specs) == 1:
        summary_path = eval_dir / f"summary-{task_specs[0]['task_name']}.csv"
    eval_scores = read_ruler_summary_scores(summary_path)
    eval_score = sum(eval_scores.values()) / len(eval_scores) if eval_scores else 0.0
    ready = int(generator_returncode == 0 and generated_task_rows == len(task_specs) and generated_rows_total > 0)
    eval_ready = int(
        eval_completed.returncode == 0
        and summary_path.is_file()
        and all(spec["task_name"] in eval_scores for spec in task_specs)
    )
    metrics = {
        "tasks": ",".join(spec["task_name"] for spec in task_specs),
        "official_generator_task_rows": len(task_specs),
        "official_generated_task_rows": generated_task_rows,
        "official_evaluated_task_rows": len(eval_scores),
        "official_generated_rows": generated_rows_total,
        "raw_prediction_rows": prediction_rows_total,
        "null_predictions": sum(1 for rows in prediction_by_task.values() for row in rows if not row["pred"]),
        "official_generator_score": eval_score,
        "official_generator_scores": eval_scores,
        "official_generator_ready": ready,
        "official_generator_evaluator_ready": eval_ready,
        "runner_owned": 1,
        "independent": 0,
        "dependency_shims_used": 1,
        "input_extractor_prediction_used": 1,
        "oracle_prediction_used": 0,
        "prediction_provenance_rows": len(prediction_provenance_rows),
        "extracted_prediction_rows": sum(int(row["extracted"]) for row in prediction_provenance_rows),
        "mmap_read_rows": mmap_store["mmap_read_rows"],
        "mmap_read_ready_rows": mmap_store["mmap_read_ready_rows"],
        "mmap_extracted_prediction_rows": mmap_store["mmap_extracted_rows"],
        "mmap_verification_ready": mmap_store["ready"],
        "claim": "Official RULER generated-row evaluator metrics; not independent external benchmark evidence",
    }
    metrics_path = ruler_dir / "official_generator_metrics.json"
    write_json(metrics_path, metrics)
    benchmark_ready = int(
        ready
        and eval_ready
        and generated_rows_total == prediction_rows_total
        and len(prediction_provenance_rows) == generated_rows_total
        and sum(int(row["extracted"]) for row in prediction_provenance_rows) == generated_rows_total
        and generated_rows_total > 0
        and prediction_provenance_path.is_file()
        and metrics_path.is_file()
        and mmap_store["ready"] == 1
        and mmap_store["mmap_extracted_rows"] == generated_rows_total
    )
    official_benchmark_rows = []
    for spec in task_specs:
        task_name = spec["task_name"]
        generated_rows = generated_by_task.get(task_name, [])
        prediction_rows = prediction_by_task.get(task_name, [])
        task_provenance_rows = [row for row in prediction_provenance_rows if row["task"] == task_name]
        task_ready = int(
            ready
            and eval_ready
            and len(generated_rows) == len(prediction_rows)
            and len(task_provenance_rows) == len(generated_rows)
            and sum(int(row["extracted"]) for row in task_provenance_rows) == len(generated_rows)
            and sum(int(row["mmap_prediction_matches_raw"]) for row in task_provenance_rows) == len(generated_rows)
            and task_name in eval_scores
        )
        official_benchmark_rows.append(
            {
            "benchmark_id": f"ruler_official_generator_{task_name}",
            "task": task_name,
            "external_benchmark_family": "ruler-official-synthetic",
            "official_generator_path": str(prepare_path) if prepare_path.is_file() else "",
            "official_evaluator_path": str(evaluator_path) if evaluator_path.is_file() else "",
            "dataset_path": str(dataset_paths[task_name]) if dataset_paths[task_name].is_file() else "",
            "prediction_path": str(prediction_paths[task_name]) if prediction_paths[task_name].is_file() else "",
            "evaluator_summary_path": str(summary_path) if summary_path.is_file() else "",
            "metrics_path": str(metrics_path),
            "prediction_provenance_path": str(prediction_provenance_path),
            "dataset_rows": len(generated_rows),
            "raw_prediction_rows": len(prediction_rows),
            "prediction_provenance_rows": len(task_provenance_rows),
            "extracted_prediction_rows": sum(int(row["extracted"]) for row in task_provenance_rows),
            "mmap_read_rows": sum(int(row["mmap_read_ready"]) for row in task_provenance_rows),
            "mmap_prediction_match_rows": sum(int(row["mmap_prediction_matches_raw"]) for row in task_provenance_rows),
            "mmap_verification_ready": int(
                bool(task_provenance_rows)
                and sum(int(row["mmap_prediction_matches_raw"]) for row in task_provenance_rows) == len(task_provenance_rows)
            ),
            "evaluator_score": f"{eval_scores.get(task_name, 0.0):.2f}",
            "dataset_bound": int(dataset_paths[task_name].is_file() and bool(generated_rows)),
            "raw_prediction_bound": int(prediction_paths[task_name].is_file() and len(prediction_rows) == len(generated_rows)),
            "prediction_provenance_bound": int(prediction_provenance_path.is_file() and len(task_provenance_rows) == len(generated_rows)),
            "evaluator_bound": eval_ready,
            "metrics_bound": int(metrics_path.is_file()),
            "runner_owned": 1,
            "independent": 0,
            "dependency_shims_used": 1,
            "input_extractor_prediction_used": 1,
            "oracle_prediction_used": 0,
            "benchmark_result_ready": task_ready,
        }
        )
    write_csv(
        ruler_dir / "official_generator_benchmark_rows.csv",
        [
            "benchmark_id",
            "task",
            "external_benchmark_family",
            "official_generator_path",
            "official_evaluator_path",
            "dataset_path",
            "prediction_path",
            "evaluator_summary_path",
            "metrics_path",
            "prediction_provenance_path",
            "dataset_rows",
            "raw_prediction_rows",
            "prediction_provenance_rows",
            "extracted_prediction_rows",
            "mmap_read_rows",
            "mmap_prediction_match_rows",
            "mmap_verification_ready",
            "evaluator_score",
            "dataset_bound",
            "raw_prediction_bound",
            "prediction_provenance_bound",
            "evaluator_bound",
            "metrics_bound",
            "runner_owned",
            "independent",
            "dependency_shims_used",
            "input_extractor_prediction_used",
            "oracle_prediction_used",
            "benchmark_result_ready",
        ],
        official_benchmark_rows,
    )
    status = {
        "official_generator_path": str(prepare_path) if prepare_path.is_file() else "",
        "official_niah_generator_path": str(generator_path) if generator_path.is_file() else "",
        "official_prepare_workspace": str(prepare_workspace),
        "official_prepare_workspace_repo": str(workspace_repo),
        "official_prepare_workspace_generator_dir": str(workspace_generator_dir),
        "official_generator_commands": [row["command"] for row in generator_results],
        "official_generator_results": generator_results,
        "official_generator_returncode": generator_returncode,
        "official_generated_dataset_paths": {
            task: str(path) for task, path in dataset_paths.items() if path.is_file()
        },
        "official_generated_rows": generated_rows_total,
        "official_generated_task_rows": generated_task_rows,
        "official_generator_ready": ready,
        "official_evaluator_command": eval_command,
        "official_generator_evaluator_returncode": eval_completed.returncode,
        "official_generator_evaluator_stdout_hash": "sha256:" + sha256_text(eval_completed.stdout),
        "official_generator_evaluator_stderr_hash": "sha256:" + sha256_text(eval_completed.stderr),
        "official_generator_evaluator_stdout_excerpt": eval_completed.stdout[-1000:],
        "official_generator_evaluator_stderr_excerpt": eval_completed.stderr[-1000:],
