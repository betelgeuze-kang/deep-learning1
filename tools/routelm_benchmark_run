def predict_and_evaluate(run_dir, dataset, route_rows, mmap_rows, emit_lineage=False, emit_generator_hint_nlg=False):
    mmap_ready = {row["query_id"]: row for row in mmap_rows}
    route_by_id = {row["query_id"]: row for row in route_rows}
    payload_by_id = route_memory_payloads(run_dir, mmap_rows)
    predictions = []
    evaluator_rows = []
    lineage_rows = []
    mmap_trace_rows = []
    candidate_trace_rows = []
    evidence_span_rows = []
    for row in dataset:
        label = row.get("label_type", "")
        query_id = row["query_id"]
        route_row = route_by_id.get(query_id, {})
        mmap_row = mmap_ready.get(query_id, {})
        payload = payload_by_id.get(query_id, {})
        payload_text = payload.get("text", "")
        payload_file, payload_line, payload_value = parse_route_memory_payload(payload_text)
        proposal_hint = route_row.get("route_key", "") or row.get("pattern", "")
        candidate_pos = payload_text.find(proposal_hint) if proposal_hint and payload_text else -1
        if candidate_pos < 0 and row.get("pattern", "") and payload_text:
            candidate_pos = payload_text.find(row.get("pattern", ""))
        mmap_read_used = int(mmap_row.get("mmap_read_ready") == 1 and bool(payload))
        value_byte_read_used = int(mmap_read_used and candidate_pos >= 0)
        candidate_value_pos_used = int(candidate_pos >= 0)
        selected_candidate_id = f"{query_id}:candidate:0"
        selected_candidate_rank = 1
        evidence_span_sha256 = payload.get("sha256", "")
        if label in {"missing", "near_miss"}:
            prediction = "ABSTAIN"
            predicted_file = ""
            predicted_symbol = ""
            prediction_source = "abstain"
            span_exact = 1
            chunk_exact = 1
            missing_abstain = 1 if label == "missing" else 0
            near_fp = 0
            wrong = 0
        else:
            predicted_file = payload_file
            predicted_symbol = proposal_hint if value_byte_read_used else ""
            prediction = f"{predicted_file}:{predicted_symbol}"
            prediction_source = "route_memory_exact" if (
                mmap_read_used
                and value_byte_read_used
                and predicted_file == row.get("expected_file", "")
                and (not row.get("expected_symbol", "") or predicted_symbol == row.get("expected_symbol", ""))
            ) else "route_memory_hint" if mmap_read_used and predicted_file else "fallback"
            span_exact = 1 if (
                row.get("expected_line", 0)
                and predicted_file == row.get("expected_file", "")
                and (not row.get("expected_symbol", "") or predicted_symbol == row.get("expected_symbol", ""))
            ) else 0
            chunk_exact = 1 if (
                mmap_read_used
                and mmap_row.get("chunk_id", "") == route_row.get("chunk_id", "")
                and predicted_file == row.get("expected_file", "")
            ) else 0
            missing_abstain = 0
            near_fp = 0
            wrong = 0 if span_exact and chunk_exact else 1
        prediction_id = "pred_" + sha256_text(f"{query_id}:{prediction}:{evidence_span_sha256}")[:16]
        prediction_sha = "sha256:" + sha256_text(prediction)
        predictions.append(
            {
                "query_id": query_id,
                "prediction_id": prediction_id,
                "prediction": prediction,
                "predicted_file": predicted_file,
                "predicted_symbol": predicted_symbol,
                "prediction_source": prediction_source,
                "backend": "cpu",
                "store_mode": "mmap",
                "jump_neighbor_used": 0,
                "raw_prediction_ready": 1,
                "oracle_prediction_used": 0,
                "input_extractor_used": 0,
                "route_memory_store_used": 1,
                "mmap_read_used": mmap_read_used,
                "candidate_value_pos_used": candidate_value_pos_used,
                "value_byte_read_used": value_byte_read_used,
                "proposal_hint_used": int(bool(proposal_hint)),
            }
        )
        lineage_row = {
            "query_id": query_id,
            "prediction_id": prediction_id,
            "prediction_source": prediction_source,
            "oracle_prediction_used": 0,
            "input_extractor_used": 0,
            "route_memory_store_used": 1,
            "mmap_read_used": mmap_read_used,
            "candidate_value_pos_used": candidate_value_pos_used,
            "value_byte_read_used": value_byte_read_used,
            "proposal_hint_used": int(bool(proposal_hint)),
            "selected_candidate_id": selected_candidate_id,
            "selected_candidate_rank": selected_candidate_rank,
            "chunk_id": mmap_row.get("chunk_id", ""),
            "byte_offset": mmap_row.get("byte_offset", ""),
            "byte_len": mmap_row.get("byte_len", ""),
            "evidence_span_sha256": evidence_span_sha256,
            "prediction_sha256": prediction_sha,
            "prediction_text": prediction,
            "proposal_hint": proposal_hint,
            "evidence_file": payload_file,
            "evidence_line": payload_line,
            "evidence_value_sha256": "sha256:" + sha256_text(payload_value) if payload_value else "",
        }
        lineage_rows.append(lineage_row)
        mmap_trace_rows.append(
            {
                "query_id": query_id,
                "prediction_id": prediction_id,
                "route_memory_store_path": "store/route_memory_store.bin",
                "route_index_path": "store/route_index.bin",
                "chunk_id": mmap_row.get("chunk_id", ""),
                "byte_offset": mmap_row.get("byte_offset", ""),
                "byte_len": mmap_row.get("byte_len", ""),
                "proposal_hint": proposal_hint,
                "candidate_value_pos": candidate_pos,
                "evidence_span_sha256": evidence_span_sha256,
                "mmap_read_used": mmap_read_used,
                "value_byte_read_used": value_byte_read_used,
            }
        )
        candidate_trace_rows.append(
            {
                "query_id": query_id,
                "prediction_id": prediction_id,
                "selected_candidate_id": selected_candidate_id,
                "selected_candidate_rank": selected_candidate_rank,
                "prediction_source": prediction_source,
                "proposal_hint": proposal_hint,
                "predicted_file": predicted_file,
                "predicted_symbol": predicted_symbol,
                "prediction_text": prediction,
                "selection_reason": "route-memory-value-byte" if value_byte_read_used else prediction_source,
            }
        )
        evidence_span_rows.append(
            {
                "query_id": query_id,
                "prediction_id": prediction_id,
                "chunk_id": mmap_row.get("chunk_id", ""),
                "byte_offset": mmap_row.get("byte_offset", ""),
                "byte_len": mmap_row.get("byte_len", ""),
                "evidence_span_sha256": evidence_span_sha256,
                "prediction_sha256": prediction_sha,
                "prediction_text": prediction,
            }
        )
        evaluator_rows.append(
            {
                "query_id": query_id,
                "label_type": label,
                "prediction": prediction,
                "span_exact": span_exact,
                "chunk_exact": chunk_exact,
                "missing_abstain": missing_abstain,
                "near_miss_false_positive": near_fp,
                "wrong_answer": wrong,
                "runner_owned_evaluator": 1,
                "independent_evaluator": 0,
            }
        )
    generator_rows, generator_trace_rows, grounding_rows = write_generator_hint_nlg(run_dir, lineage_rows, emit_generator_hint_nlg)
    if emit_lineage:
        write_jsonl(run_dir / "predictions" / "prediction_lineage.jsonl", lineage_rows)
        write_jsonl(run_dir / "traces" / "mmap_prediction_trace.jsonl", mmap_trace_rows)
        write_jsonl(run_dir / "traces" / "selected_candidate_trace.jsonl", candidate_trace_rows)
        write_csv(run_dir / "evidence" / "prediction_source_rows.csv", prediction_lineage_fieldnames(), lineage_rows)
        write_csv(run_dir / "evidence" / "route_memory_prediction_rows.csv", prediction_lineage_fieldnames(), lineage_rows)
        write_csv(
            run_dir / "evidence" / "evidence_span_to_prediction.csv",
            [
                "query_id",
                "prediction_id",
                "chunk_id",
                "byte_offset",
                "byte_len",
                "evidence_span_sha256",
                "prediction_sha256",
                "prediction_text",
            ],
            evidence_span_rows,
        )
    return predictions, evaluator_rows, {
        "lineage_rows": lineage_rows,
        "mmap_trace_rows": mmap_trace_rows,
        "candidate_trace_rows": candidate_trace_rows,
        "evidence_span_rows": evidence_span_rows,
        "generator_rows": generator_rows,
        "generator_trace_rows": generator_trace_rows,
        "grounding_rows": grounding_rows,
    }


def compute_metrics(rows):
    total = len(rows) or 1
    missing = [row for row in rows if row["label_type"] == "missing"]
    near = [row for row in rows if row["label_type"] == "near_miss"]
    return {
        "span_exact": sum(int(row["span_exact"]) for row in rows) / total,
        "chunk_exact": sum(int(row["chunk_exact"]) for row in rows) / total,
        "missing_abstain": sum(int(row["missing_abstain"]) for row in missing) / (len(missing) or 1),
        "near_miss_false_positive": sum(int(row["near_miss_false_positive"]) for row in near) / (len(near) or 1),
        "wrong_answer_rate": sum(int(row["wrong_answer"]) for row in rows) / total,
    }


def string_match_all(preds, refs):
    if not preds:
        return 0.0
    score = 0.0
    for pred, ref in zip(preds, refs):
        if not ref:
            continue
        score += sum(1.0 if str(item).lower() in pred.lower() else 0.0 for item in ref) / len(ref)
    return round(score / len(preds) * 100.0, 2)


def read_ruler_summary_score(summary_path):
    scores = read_ruler_summary_scores(summary_path)
    if not scores:
        return 0.0
    return sum(scores.values()) / len(scores)


def read_ruler_summary_scores(summary_path):
    if not summary_path.is_file():
        return {}
    tasks = []
    score_values = []
    with summary_path.open(newline="", encoding="utf-8") as handle:
        for row in csv.reader(handle):
            if len(row) >= 2 and row[0] == "Tasks":
                tasks = row[1:]
            if len(row) >= 2 and row[0] == "Score":
                score_values = row[1:]
    scores = {}
    for task, score_value in zip(tasks, score_values):
        try:
            scores[task] = float(score_value)
        except ValueError:
            scores[task] = 0.0
    return scores


def extract_ruler_niah_prediction(row):
    text = str(row.get("input", ""))
    answer_prefix = str(row.get("answer_prefix", ""))
    key = ""
    match = re.search(r"\bfor\s+(.+?)\s+mentioned\b", answer_prefix)
    if match:
        key = match.group(1).strip()
    if not key:
        match = re.search(r"special magic (?:numbers?|words?|uuids?)\s+for\s+(.+?)\s+mentioned", text)
        if match:
            key = match.group(1).strip()
    if not key:
        return "", "", 0

    needle_re = re.compile(
        r"One of the special magic (?:numbers?|words?|uuids?)\s+for\s+"
        + re.escape(key)
        + r"\s+is:\s*([A-Za-z0-9-]+)\.",
        re.IGNORECASE,
    )
    match = needle_re.search(text)
    if not match:
        return key, "", 0
    return key, match.group(1).strip(), 1


def write_ruler_generated_mmap_store(
    ruler_dir,
    generated_by_task,
    store_name="official_generator_store",
    store_scope="ruler-official-generated-mmap-verification-store",
):
    store_dir = ruler_dir / store_name
    store_dir.mkdir(parents=True, exist_ok=True)
    chunk_pages = store_dir / "chunk_pages.bin"
    offsets = []
    cursor = 0
    with chunk_pages.open("wb") as handle:
        for task in sorted(generated_by_task):
            for row_index, row in enumerate(generated_by_task[task]):
                source_index = row.get("index", row_index)
                chunk_id = f"{task}:{source_index}"
                payload = json.dumps(
                    {
                        "task": task,
                        "index": source_index,
                        "input": row.get("input", ""),
                        "answer_prefix": row.get("answer_prefix", ""),
                    },
                    sort_keys=True,
                ).encode("utf-8") + b"\n"
                handle.write(payload)
                offsets.append(
                    {
                        "task": task,
                        "index": source_index,
                        "chunk_id": chunk_id,
                        "byte_offset": cursor,
                        "byte_len": len(payload),
                    }
                )
                cursor += len(payload)
    write_csv(
        store_dir / "chunk_offsets.csv",
        ["task", "index", "chunk_id", "byte_offset", "byte_len"],
        offsets,
    )
    write_csv(
        store_dir / "chunk_offsets",
        ["task", "index", "chunk_id", "byte_offset", "byte_len"],
        offsets,
    )
    route_index_path = store_dir / "route_index.bin"
    route_index_path.write_bytes(json.dumps(offsets, sort_keys=True).encode("utf-8"))
    route_store_path = store_dir / "route_memory_store.bin"
    shutil.copy2(chunk_pages, route_store_path)
    mmap_rows = []
    prediction_by_key = {}
    if chunk_pages.stat().st_size:
        with chunk_pages.open("rb") as handle:
            mm = mmap.mmap(handle.fileno(), 0, access=mmap.ACCESS_READ)
            try:
                for offset in offsets:
                    start = int(offset["byte_offset"])
                    length = int(offset["byte_len"])
                    payload = mm[start : start + length]
                    mmap_row = {
                        "task": offset["task"],
                        "index": offset["index"],
                        "chunk_id": offset["chunk_id"],
                        "byte_offset": start,
                        "byte_len": length,
                        "mmap_read_hash": "sha256:" + hashlib.sha256(payload).hexdigest(),
                        "mmap_read_ready": 1,
                    }
                    try:
                        payload_row = json.loads(payload.decode("utf-8"))
                        query_key, pred, extracted = extract_ruler_niah_prediction(payload_row)
                    except Exception:
                        query_key, pred, extracted = "", "", 0
                    mmap_row.update(
                        {
                            "query_key": query_key,
                            "mmap_extracted_pred": pred,
                            "mmap_extracted": extracted,
                        }
                    )
                    mmap_rows.append(mmap_row)
                    prediction_by_key[(str(offset["task"]), str(offset["index"]))] = mmap_row
            finally:
                mm.close()
    mmap_rows_path = store_dir / "mmap_read_rows.csv"
    write_csv(
        mmap_rows_path,
        [
            "task",
            "index",
            "chunk_id",
            "byte_offset",
            "byte_len",
            "mmap_read_hash",
            "mmap_read_ready",
            "query_key",
            "mmap_extracted_pred",
            "mmap_extracted",
        ],
        mmap_rows,
    )
    write_csv(
        store_dir / "store_manifest.csv",
        ["artifact", "path", "sha256"],
        [
            {"artifact": "chunk_pages", "path": str(chunk_pages), "sha256": "sha256:" + sha256(chunk_pages)},
            {"artifact": "chunk_offsets", "path": str(store_dir / "chunk_offsets"), "sha256": "sha256:" + sha256(store_dir / "chunk_offsets")},
            {"artifact": "route_memory_store", "path": str(route_store_path), "sha256": "sha256:" + sha256(route_store_path)},
            {"artifact": "route_index", "path": str(route_index_path), "sha256": "sha256:" + sha256(route_index_path)},
            {"artifact": "mmap_read_rows", "path": str(mmap_rows_path), "sha256": "sha256:" + sha256(mmap_rows_path)},
        ],
    )
    status = {
        "store_scope": store_scope,
        "dataset_rows": sum(len(rows) for rows in generated_by_task.values()),
        "chunk_rows": len(offsets),
        "mmap_read_rows": len(mmap_rows),
        "mmap_read_ready_rows": sum(int(row["mmap_read_ready"]) for row in mmap_rows),
        "mmap_extracted_rows": sum(int(row["mmap_extracted"]) for row in mmap_rows),
        "chunk_pages_path": str(chunk_pages),
        "route_memory_store_path": str(route_store_path),
        "route_index_path": str(route_index_path),
        "chunk_offsets_path": str(store_dir / "chunk_offsets"),
        "mmap_read_rows_path": str(mmap_rows_path),
        "store_manifest_path": str(store_dir / "store_manifest.csv"),
        "ready": int(bool(offsets) and len(offsets) == len(mmap_rows) and all(int(row["mmap_read_ready"]) == 1 for row in mmap_rows)),
        "claim": "mmap verification store for RULER NIAH inputs and extracted predictions",
    }
    status_path = store_dir / "store_status.json"
    write_json(status_path, status)
    return {
        "store_dir": store_dir,
        "status_path": status_path,
        "mmap_rows_path": mmap_rows_path,
        "prediction_by_key": prediction_by_key,
        "mmap_read_rows": len(mmap_rows),
        "mmap_read_ready_rows": status["mmap_read_ready_rows"],
        "mmap_extracted_rows": status["mmap_extracted_rows"],
        "ready": status["ready"],
    }


