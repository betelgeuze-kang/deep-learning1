def write_shortcut_negative_suite(run_dir, enabled):
    if not enabled:
        return {
            "shortcut_negative_suite_ready": 0,
            "negative_case_rows": 0,
            "hash_clean_wrong_span_block": 0,
            "corrupted_route_index_block": 0,
            "corrupted_chunk_offsets_block": 0,
            "input_extractor_promotion_block": 0,
            "oracle_promotion_block": 0,
        }
    cases = [
        ("answer_absent", "abstain", "answer_absent_block"),
        ("near_miss_needle", "abstain", "near_miss_reject_block"),
        ("duplicate_key", "route_memory_hint", "duplicate_key_requires_mmap_span"),
        ("same_key_wrong_value", "abstain", "same_key_wrong_value_block"),
        ("shifted_chunk_offset", "fallback", "shifted_chunk_offset_block"),
        ("hash_clean_wrong_span", "fallback", "hash_clean_wrong_span_block"),
        ("corrupted_route_index", "fallback", "corrupted_route_index_block"),
        ("corrupted_chunk_offsets", "fallback", "corrupted_chunk_offsets_block"),
        ("raw_input_contains_answer_but_store_masked", "input_extractor", "raw_input_shortcut_block"),
        ("store_contains_answer_but_raw_input_masked", "route_memory_exact", "store_masked_input_pass"),
        ("oracle_answer_available", "oracle", "oracle_promotion_block"),
    ]
    rows = []
    for index, (case_id, attempted_source, block_reason) in enumerate(cases, 1):
        attempted_oracle = int(attempted_source == "oracle")
        attempted_extractor = int(attempted_source == "input_extractor")
        route_memory_source = int(attempted_source in {"route_memory_exact", "route_memory_hint", "abstain", "fallback"})
        promotion_allowed = int(
            route_memory_source
            and case_id not in {
                "shifted_chunk_offset",
                "hash_clean_wrong_span",
                "corrupted_route_index",
                "corrupted_chunk_offsets",
                "same_key_wrong_value",
            }
