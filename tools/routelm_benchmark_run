    write_csv(
        run_dir / "evidence" / "shortcut_negative_rows.csv",
        [
            "case_id",
            "case_index",
            "attempted_prediction_source",
            "oracle_prediction_used",
            "input_extractor_used",
            "route_memory_store_used",
            "mmap_read_used",
