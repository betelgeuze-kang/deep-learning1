def write_generator_hint_nlg(run_dir, lineage_rows, enabled):
    generator_rows = []
    trace_rows = []
    grounding_rows = []
    if not enabled:
        return generator_rows, trace_rows, grounding_rows
    for row in lineage_rows:
        proposal_hint = row.get("proposal_hint", "")
        prediction_text = row.get("prediction_text", "")
        evidence_hash = row.get("evidence_span_sha256", "")
        output = (
            f"RouteMemory hint {proposal_hint} selected {prediction_text} "
            f"from evidence {evidence_hash}."
        ) if proposal_hint else (
            f"RouteMemory abstained for {row.get('query_id', '')} from evidence {evidence_hash}."
        )
        generator_input = {
            "query_id": row.get("query_id", ""),
            "prediction_id": row.get("prediction_id", ""),
            "proposal_hint": proposal_hint,
            "prediction_text": prediction_text,
            "evidence_span_sha256": evidence_hash,
        }
        generator_rows.append(
            {
                "query_id": row.get("query_id", ""),
                "prediction_id": row.get("prediction_id", ""),
                "generator_kind": "tiny_template_generator_hint_nlg",
                "proposal_hint": proposal_hint,
                "proposal_hint_used": int(bool(proposal_hint)),
                "prediction_text": prediction_text,
                "generator_input_sha256": "sha256:" + sha256_text(json.dumps(generator_input, sort_keys=True)),
                "generator_output_sha256": "sha256:" + sha256_text(output),
                "generator_output": output,
                "answer_generation_uses_prediction_lineage": 1,
                "oracle_prediction_used": 0,
                "input_extractor_used": 0,
            }
        )
        trace_rows.append(
            {
                "query_id": row.get("query_id", ""),
                "prediction_id": row.get("prediction_id", ""),
                "proposal_hint": proposal_hint,
                "proposal_hint_seen_in_output": int(bool(proposal_hint) and proposal_hint in output),
                "prediction_text_seen_in_output": int(bool(prediction_text) and prediction_text in output),
            }
        )
        grounding_rows.append(
            {
