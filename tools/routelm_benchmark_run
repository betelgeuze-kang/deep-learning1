def sha256(path):
    h = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def sha256_text(text):
    return hashlib.sha256(text.encode("utf-8")).hexdigest()


def write_json(path, payload):
    path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def write_jsonl(path, rows):
    with path.open("w", encoding="utf-8") as handle:
        for row in rows:
            handle.write(json.dumps(row, sort_keys=True) + "\n")


def write_csv(path, fieldnames, rows):
    with path.open("w", newline="", encoding="utf-8") as handle:
        writer = csv.DictWriter(handle, fieldnames=fieldnames, lineterminator="\n", extrasaction="ignore")
        writer.writeheader()
        writer.writerows(rows)


def read_csv_rows(path):
    if not path or not Path(path).is_file():
        return []
    with Path(path).open(newline="", encoding="utf-8") as handle:
        return list(csv.DictReader(handle))


def read_queries(path):
    if not path:
        return list(BUILTIN_QUERIES)
    rows = []
    with Path(path).open(encoding="utf-8") as handle:
        for line in handle:
            if line.strip():
                rows.append(json.loads(line))
    for index, row in enumerate(rows, 1):
        if not row.get("query_id"):
            raise ValueError(f"query row {index} is missing query_id")
        row.setdefault("query_type", "lookup")
        row.setdefault("label_type", "present")
        row.setdefault("expected_file", "")
        row.setdefault("expected_symbol", "")
        row.setdefault("pattern", "")
        row.setdefault("query_text", "")
    return rows


def routeqa_mini_symbol(line):
    common = {
        "const",
        "return",
        "include",
        "static",
        "void",
        "auto",
        "int",
        "double",
        "float",
        "class",
        "struct",
        "namespace",
        "using",
        "for",
        "while",
        "if",
        "else",
        "elif",
        "def",
        "import",
        "from",
        "local",
    }
    for token in re.findall(r"[A-Za-z_][A-Za-z0-9_]{2,}", line):
        if token.lower() not in common:
            return token
    return "line_" + sha256_text(line)[:12]


def build_routeqa_mini_queries(repo, base_queries, target_rows):
    if target_rows <= 0 or len(base_queries) >= target_rows:
        return list(base_queries)
    queries = [dict(row) for row in base_queries]
    seen_patterns = {(row.get("expected_file", ""), row.get("pattern", "")) for row in queries}
    candidates = []
    include_suffixes = {".cpp", ".hpp", ".h", ".c", ".py", ".sh", ".md", ".txt", ".jsonl", ".cmake"}
    include_names = {"CMakeLists.txt", "README.md", "README.ko.md"}
    skip_dirs = {".git", "results", ".betelgeuze", "__pycache__", ".pytest_cache"}
    for path in sorted(repo.rglob("*")):
        if not path.is_file():
            continue
        rel_parts = path.relative_to(repo).parts
        if any(part in skip_dirs for part in rel_parts):
            continue
        if path.name not in include_names and path.suffix not in include_suffixes:
            continue
        try:
            if path.stat().st_size > 256 * 1024:
                continue
            lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
        except OSError:
            continue
        rel = str(path.relative_to(repo))
        for line_no, line in enumerate(lines, 1):
            stripped = line.strip()
            if len(stripped) < 18 or stripped.startswith("#!") or stripped.startswith("---"):
                continue
            if len(stripped) > 180:
                stripped = stripped[:180]
            key = (rel, stripped)
            if key in seen_patterns:
                continue
            symbol = routeqa_mini_symbol(stripped)
            candidates.append(
                {
                    "query_id": f"routeqa_mini_{len(candidates) + 1:04d}_{sha256_text(rel + ':' + str(line_no) + ':' + stripped)[:10]}",
                    "query_type": "routeqa_mini_line_lookup",
                    "label_type": "present",
                    "expected_file": rel,
                    "expected_symbol": symbol,
                    "pattern": stripped,
                    "query_text": f"Find the RouteQA-mini evidence line for {symbol}.",
                }
            )
            seen_patterns.add(key)
            if len(queries) + len(candidates) >= target_rows:
                return queries + candidates
    return queries + candidates


def find_pattern(repo, rel, pattern):
    path = repo / rel
    if not path.is_file():
        return 0, 0, ""
    for line_no, line in enumerate(path.read_text(encoding="utf-8", errors="replace").splitlines(), 1):
        pos = line.find(pattern)
        if pos >= 0:
            return line_no, pos, line
    return 0, 0, ""


def copy_optional(path, dst):
    if path and Path(path).is_file():
        shutil.copy2(path, dst)
        return True
    return False


def resolve_related_source_chain_path(source_acquisition_path, explicit_path, filename):
    if explicit_path:
        return explicit_path, 0
    if not source_acquisition_path:
        return "", 0
    source_path = Path(source_acquisition_path)
    if not source_path.is_file():
        return "", 0
    parent = source_path.parent
    candidates = [
        parent / filename,
        parent.parent / "source" / filename,
        parent.parent / filename,
    ]
    for candidate in candidates:
        if candidate.is_file():
            return str(candidate), 1
    return "", 0


