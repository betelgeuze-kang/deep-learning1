        rows.append(
            {
                "case_id": case_id,
                "case_index": index,
                "attempted_prediction_source": attempted_source,
                "oracle_prediction_used": attempted_oracle,
                "input_extractor_used": attempted_extractor,
                "route_memory_store_used": int(route_memory_source),
                "mmap_read_used": int(route_memory_source),
