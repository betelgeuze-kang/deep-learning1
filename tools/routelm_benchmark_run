def parse_longbench_result_text(path):
    table = parse_longbench_result_table(path)
    if not table:
        return {}
    return next(iter(table.values()))


def parse_longbench_result_table(path):
    if not path.is_file():
        return {}
    lines = [line.strip() for line in path.read_text(encoding="utf-8").splitlines() if line.strip()]
    if len(lines) < 2:
        return {}
    header = lines[0].split("\t")
    table = {}
    for line in lines[1:]:
        values = line.split("\t")
        if len(header) != len(values):
            continue
        result = dict(zip(header, values))
        scores = {}
        for key, value in result.items():
            if key == "Model":
                scores[key] = value
                continue
            try:
                scores[key] = float(value)
            except ValueError:
                scores[key] = 0.0
        model = str(scores.get("Model", ""))
        if model:
            table[model] = scores
    return table


def fetch_url_text(url, timeout=60):
    with urlopen(url, timeout=timeout) as response:
        return response.read().decode("utf-8")


def longbench_choice_baseline(row):
    haystack = f"{row.get('question', '')}\n{row.get('context', '')}".lower()
    best_label = "A"
    best_score = -1
    for label in ["A", "B", "C", "D"]:
        choice = str(row.get(f"choice_{label}", ""))
        tokens = [token for token in re.findall(r"[A-Za-z0-9가-힣]+", choice.lower()) if len(token) >= 4]
        exact = 5 if choice and choice.lower() in haystack else 0
        token_hits = sum(1 for token in tokens[:12] if token in haystack)
        score = exact + token_hits
        if score > best_score:
            best_label = label
            best_score = score
    return best_label, max(best_score, 0)


def write_longbench_official_sample_mmap_store(longbench_dir, sample_rows, prediction_rows):
    store_dir = longbench_dir / "official_sample_store"
    store_dir.mkdir(parents=True, exist_ok=True)
    chunk_pages = store_dir / "chunk_pages.bin"
    offsets = []
    cursor = 0
    with chunk_pages.open("wb") as handle:
        for index, row in enumerate(sample_rows):
            row_id = str(row.get("_id", index))
            chunk_id = f"longbench_v2_official_sample:{row_id}"
            payload = json.dumps(row, sort_keys=True).encode("utf-8") + b"\n"
            handle.write(payload)
            offsets.append(
                {
                    "index": index,
                    "_id": row_id,
                    "chunk_id": chunk_id,
                    "byte_offset": cursor,
                    "byte_len": len(payload),
                }
            )
            cursor += len(payload)
    write_csv(
        store_dir / "chunk_offsets.csv",
        ["index", "_id", "chunk_id", "byte_offset", "byte_len"],
        offsets,
    )
    write_csv(
        store_dir / "chunk_offsets",
        ["index", "_id", "chunk_id", "byte_offset", "byte_len"],
        offsets,
    )
    route_index_path = store_dir / "route_index.bin"
    route_index_path.write_bytes(json.dumps(offsets, sort_keys=True).encode("utf-8"))
    route_store_path = store_dir / "route_memory_store.bin"
    shutil.copy2(chunk_pages, route_store_path)
    expected_by_id = {str(row.get("_id", "")): str(row.get("pred", "")) for row in prediction_rows}
    mmap_rows = []
    prediction_by_id = {}
    if chunk_pages.stat().st_size:
        with chunk_pages.open("rb") as handle:
            mm = mmap.mmap(handle.fileno(), 0, access=mmap.ACCESS_READ)
            try:
                for offset in offsets:
                    start = int(offset["byte_offset"])
                    length = int(offset["byte_len"])
                    payload = mm[start : start + length]
                    try:
                        payload_row = json.loads(payload.decode("utf-8"))
                        pred, baseline_score = longbench_choice_baseline(payload_row)
                    except Exception:
                        pred, baseline_score = "", 0
                    expected_pred = expected_by_id.get(str(offset["_id"]), "")
                    mmap_row = {
                        "index": offset["index"],
                        "_id": offset["_id"],
                        "chunk_id": offset["chunk_id"],
                        "byte_offset": start,
                        "byte_len": length,
                        "mmap_read_hash": "sha256:" + hashlib.sha256(payload).hexdigest(),
                        "mmap_read_ready": 1,
                        "mmap_baseline": "context_choice_lexical_overlap",
                        "mmap_baseline_score": baseline_score,
                        "mmap_pred": pred,
                        "mmap_prediction_matches_raw": int(bool(expected_pred) and pred == expected_pred),
                    }
                    mmap_rows.append(mmap_row)
                    prediction_by_id[str(offset["_id"])] = mmap_row
            finally:
                mm.close()
    mmap_rows_path = store_dir / "mmap_read_rows.csv"
    write_csv(
        mmap_rows_path,
        [
            "index",
            "_id",
            "chunk_id",
            "byte_offset",
            "byte_len",
            "mmap_read_hash",
            "mmap_read_ready",
            "mmap_baseline",
            "mmap_baseline_score",
            "mmap_pred",
            "mmap_prediction_matches_raw",
        ],
        mmap_rows,
    )
    write_csv(
        store_dir / "store_manifest.csv",
        ["artifact", "path", "sha256"],
        [
            {"artifact": "chunk_pages", "path": str(chunk_pages), "sha256": "sha256:" + sha256(chunk_pages)},
            {"artifact": "chunk_offsets", "path": str(store_dir / "chunk_offsets"), "sha256": "sha256:" + sha256(store_dir / "chunk_offsets")},
            {"artifact": "route_memory_store", "path": str(route_store_path), "sha256": "sha256:" + sha256(route_store_path)},
            {"artifact": "route_index", "path": str(route_index_path), "sha256": "sha256:" + sha256(route_index_path)},
            {"artifact": "mmap_read_rows", "path": str(mmap_rows_path), "sha256": "sha256:" + sha256(mmap_rows_path)},
        ],
    )
    status = {
        "store_scope": "longbench-v2-official-sample-mmap-verification-store",
        "dataset_rows": len(sample_rows),
        "chunk_rows": len(offsets),
        "mmap_read_rows": len(mmap_rows),
        "mmap_read_ready_rows": sum(int(row["mmap_read_ready"]) for row in mmap_rows),
        "mmap_prediction_match_rows": sum(int(row["mmap_prediction_matches_raw"]) for row in mmap_rows),
        "chunk_pages_path": str(chunk_pages),
        "route_memory_store_path": str(route_store_path),
        "route_index_path": str(route_index_path),
        "chunk_offsets_path": str(store_dir / "chunk_offsets"),
        "mmap_read_rows_path": str(mmap_rows_path),
        "store_manifest_path": str(store_dir / "store_manifest.csv"),
        "ready": int(
            bool(offsets)
            and len(offsets) == len(mmap_rows)
            and all(int(row["mmap_read_ready"]) == 1 for row in mmap_rows)
            and all(int(row["mmap_prediction_matches_raw"]) == 1 for row in mmap_rows)
        ),
        "claim": "mmap verification store for LongBench v2 official dataset-server sample rows and lexical baseline predictions",
    }
    status_path = store_dir / "store_status.json"
    write_json(status_path, status)
    return {
        "store_dir": store_dir,
        "status_path": status_path,
        "mmap_rows_path": mmap_rows_path,
        "prediction_by_id": prediction_by_id,
        "mmap_read_rows": len(mmap_rows),
        "mmap_read_ready_rows": status["mmap_read_ready_rows"],
        "mmap_prediction_match_rows": status["mmap_prediction_match_rows"],
        "ready": status["ready"],
    }


