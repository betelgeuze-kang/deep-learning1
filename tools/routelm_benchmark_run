                "candidate_promotion_blocked": int(not promotion_allowed),
                "hash_clean_wrong_span_block": int(case_id == "hash_clean_wrong_span" and not promotion_allowed),
                "corrupted_route_index_block": int(case_id == "corrupted_route_index" and not promotion_allowed),
                "corrupted_chunk_offsets_block": int(case_id == "corrupted_chunk_offsets" and not promotion_allowed),
                "raw_input_shortcut_block": int(case_id == "raw_input_contains_answer_but_store_masked" and not promotion_allowed),
                "input_extractor_promotion_block": int(attempted_extractor and not promotion_allowed),
                "oracle_promotion_block": int(attempted_oracle and not promotion_allowed),
                "block_reason": block_reason,
