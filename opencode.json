{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/glm-5.2",
  "instructions": [
    "AGENTS.md",
    "docs/ai/profiles/deep-learning-research.md"
  ],
  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "external_directory": "deny",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "edit": "allow",
    "bash": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "task": "deny",
    "todowrite": "allow"
  }
}
