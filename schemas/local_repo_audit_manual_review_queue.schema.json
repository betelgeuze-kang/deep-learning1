{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "claim_boundary",
    "release_ready",
    "public_comparison_claim_ready",
    "real_model_execution_ready",
    "manual_review_queue_rows",
    "rows"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit_manual_review_queue.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "claim_boundary": {"const": "alpha-local-code-doc-audit-only"},
    "release_ready": {"const": 0},
    "public_comparison_claim_ready": {"const": 0},
    "real_model_execution_ready": {"const": 0},
    "manual_review_queue_rows": {"type": "integer", "minimum": 1},
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "review_queue_id",
          "review_types",
          "manual_review_required",
          "review_reason",
          "auto_promoted"
        ],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "review_queue_id": {"type": "string", "minLength": 1},
          "review_types": {"const": "accuracy|citation_correctness|false_positive"},
          "manual_review_required": {"type": "integer", "enum": [1]},
          "review_reason": {"type": "string", "minLength": 1},
          "auto_promoted": {"type": "integer", "enum": [0]}
        }
      }
    }
  }
}
