{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_source_snapshot.schema.json",
  "title": "Local repo audit source snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "target_repo",
    "source_manifest_sha256",
    "source_file_count",
    "git_available",
    "git_head",
    "git_dirty",
    "git_status_sha256",
    "git_tracked_files"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit_source_snapshot.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "target_repo": {"type": "string", "minLength": 1},
    "source_manifest_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "source_file_count": {"type": "integer", "minimum": 1},
    "git_available": {"type": "integer", "enum": [0, 1]},
    "git_head": {"type": "string", "pattern": "^(|[0-9a-f]{40})$"},
    "git_dirty": {"type": "integer", "enum": [0, 1]},
    "git_status_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "git_tracked_files": {"type": "integer", "minimum": 0}
  }
}
