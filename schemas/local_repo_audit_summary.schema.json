{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_summary.schema.json",
  "title": "Local repo audit summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "audit_my_repo_ready",
    "target_repo",
    "mode",
    "namespace",
    "generator",
    "question_supplied",
    "source_files",
    "finding_rows",
    "citation_span_rows",
    "abstain_rows",
    "unsupported_claim_rows",
    "accuracy_rows",
    "citation_correctness_rows",
    "false_positive_candidate_rows",
    "wrong_answer_guard_rows",
    "wrong_answer_guard_pass_rows",
    "claim_boundary_ready",
    "route_memory_lineage_rows",
    "mmap_read_trace_rows",
    "compact_route_hint_rows",
    "grounded_generation_rows",
    "raw_prompt_context_bytes",
    "attention_blocks",
    "transformer_blocks",
    "oracle_prediction_used",
    "raw_input_extractor_used",
    "real_release_package_ready",
    "public_comparison_claim_ready",
    "gpu_speedup_claim",
    "latency_ms"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "audit_my_repo_ready": {"const": 1},
    "target_repo": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "enum": ["quick", "full"]},
    "namespace": {"type": "string", "enum": ["fixture", "synthetic", "real_benchmark"]},
    "generator": {"const": "routehint-tiny"},
    "question_supplied": {"type": "integer", "minimum": 0, "maximum": 1},
    "source_files": {"type": "integer", "minimum": 1},
    "finding_rows": {"type": "integer", "minimum": 1},
    "citation_span_rows": {"type": "integer", "minimum": 1},
    "abstain_rows": {"type": "integer", "minimum": 0},
    "unsupported_claim_rows": {"type": "integer", "minimum": 0},
    "accuracy_rows": {"type": "integer", "minimum": 1},
    "citation_correctness_rows": {"type": "integer", "minimum": 1},
    "false_positive_candidate_rows": {"type": "integer", "minimum": 1},
    "wrong_answer_guard_rows": {"type": "integer", "minimum": 1},
    "wrong_answer_guard_pass_rows": {"type": "integer", "minimum": 1},
    "claim_boundary_ready": {"const": 1},
    "route_memory_lineage_rows": {"type": "integer", "minimum": 1},
    "mmap_read_trace_rows": {"type": "integer", "minimum": 1},
    "compact_route_hint_rows": {"type": "integer", "minimum": 1},
    "grounded_generation_rows": {"type": "integer", "minimum": 1},
    "raw_prompt_context_bytes": {"const": 0},
    "attention_blocks": {"const": 0},
    "transformer_blocks": {"const": 0},
    "oracle_prediction_used": {"const": 0},
    "raw_input_extractor_used": {"const": 0},
    "real_release_package_ready": {"const": 0},
    "public_comparison_claim_ready": {"const": 0},
    "gpu_speedup_claim": {"const": "deferred"},
    "latency_ms": {"const": 0}
  }
}
