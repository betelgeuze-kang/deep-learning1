{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/v58_blind_eval.schema.json",
  "title": "v58 Real Blind Evaluation Contract",
  "type": "object",
  "required": ["schema_version", "policy", "required_systems", "requirements", "required_artifacts"],
  "properties": {
    "schema_version": {"type": "string"},
    "policy": {
      "type": "object",
      "required": [
        "fixture_allowed",
        "tests_only_merge_condition",
        "real_execution_ready",
        "human_blind_review_ready",
        "inter_rater_rows_ready",
        "v58_full_blind_eval_ready",
        "release_ready",
        "required_real_response_systems",
        "required_independent_reviewers_per_response",
        "blind_identity_required_until_adjudication",
        "response_text_identity_leakage_forbidden",
        "adjudication_required_for_disagreement",
        "unseen_repository_split_required",
        "source_span_exactness_separate_score",
        "unsupported_abstention_separate_score",
        "latency_memory_quality_separated"
      ],
      "properties": {
        "fixture_allowed": {"type": "boolean"},
        "tests_only_merge_condition": {"type": "boolean"},
        "real_execution_ready": {"type": "boolean"},
        "human_blind_review_ready": {"type": "boolean"},
        "inter_rater_rows_ready": {"type": "boolean"},
        "v58_full_blind_eval_ready": {"type": "boolean"},
        "release_ready": {"type": "boolean"},
        "required_real_response_systems": {"type": "array", "items": {"type": "string"}},
        "required_independent_reviewers_per_response": {"type": "integer", "minimum": 2},
        "blind_identity_required_until_adjudication": {"type": "boolean"},
        "response_text_identity_leakage_forbidden": {"type": "boolean"},
        "adjudication_required_for_disagreement": {"type": "boolean"},
        "unseen_repository_split_required": {"type": "boolean"},
        "source_span_exactness_separate_score": {"type": "boolean"},
        "unsupported_abstention_separate_score": {"type": "boolean"},
        "latency_memory_quality_separated": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "required_systems": {"type": "array", "items": {"type": "string"}},
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["requirement_id", "required_evidence"],
        "properties": {
          "requirement_id": {"type": "string"},
          "required_evidence": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_kind", "validation_command", "required_columns", "min_rows"],
        "properties": {
          "artifact_id": {"type": "string"},
          "artifact_kind": {"type": "string"},
          "validation_command": {"type": "string"},
          "required_columns": {"type": "array", "items": {"type": "string"}},
          "min_rows": {"type": "integer", "minimum": 1},
          "per_system_min_rows": {
            "type": "object",
            "required": ["A", "B", "C", "D", "E", "G", "H"],
            "properties": {
              "A": {"const": 500},
              "B": {"const": 500},
              "C": {"const": 500},
              "D": {"const": 500},
              "E": {"const": 500},
              "G": {"const": 500},
              "H": {"const": 500}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "x-contract": {
    "expected_policy_static": {
      "fixture_allowed": false,
      "tests_only_merge_condition": false,
      "real_execution_ready": false,
      "human_blind_review_ready": false,
      "inter_rater_rows_ready": false,
      "v58_full_blind_eval_ready": false,
      "release_ready": false,
      "required_real_response_systems": ["A", "B", "C", "D", "E", "G", "H"],
      "required_independent_reviewers_per_response": 2,
      "blind_identity_required_until_adjudication": true,
      "response_text_identity_leakage_forbidden": true,
      "adjudication_required_for_disagreement": true,
      "unseen_repository_split_required": true,
      "source_span_exactness_separate_score": true,
      "unsupported_abstention_separate_score": true,
      "latency_memory_quality_separated": true
    },
    "expected_required_systems": ["A", "B", "C", "D", "E", "G", "H"],
    "expected_requirement_ids": [
      "ab-cdegh-real-responses",
      "same-corpus-context-budget",
      "blind-identity",
      "two-independent-reviewers",
      "disagreement-adjudication",
      "unseen-repository-split",
      "source-span-exactness",
      "unsupported-abstention",
      "latency-memory-separate"
    ],
    "expected_required_artifacts": [
      {
        "artifact_id": "v58-blind-response-rows",
        "artifact_kind": "csv",
        "validation_command": "V58C_BLIND_RESPONSE_EVIDENCE_DIR=<BLIND_RESPONSE_DIR> ./experiments/test_v58c_blind_response_evidence_intake.sh",
        "required_columns": ["blind_response_id", "blind_eval_id", "query_id", "blind_system_id", "response_text", "citation_source_span_id", "abstained", "output_sha256", "latency_ns", "memory_peak_bytes", "cost_usd", "model_run_id", "credential_redacted", "resource_trace_sha256", "frozen_query_packet_sha256", "source_manifest_sha256", "context_budget", "retrieval_budget", "latency_memory_excluded_from_quality_score"],
        "min_rows": 3500,
        "per_system_min_rows": {"A": 500, "B": 500, "C": 500, "D": 500, "E": 500, "G": 500, "H": 500}
      },
      {
        "artifact_id": "v58-run-identity-rows",
        "artifact_kind": "csv",
        "validation_command": "V58C_BLIND_RESPONSE_EVIDENCE_DIR=<BLIND_RESPONSE_DIR> ./experiments/test_v58c_blind_response_evidence_intake.sh",
        "required_columns": ["blind_system_id", "source_system_id", "model_or_architecture_id", "corpus_id", "context_budget", "retrieval_budget", "prompt_template_sha256", "source_manifest_sha256", "external_api_used"],
        "min_rows": 7
      },
      {
        "artifact_id": "v58-query-split-rows",
        "artifact_kind": "csv",
        "validation_command": "V58C_BLIND_RESPONSE_EVIDENCE_DIR=<BLIND_RESPONSE_DIR> ./experiments/test_v58c_blind_response_evidence_intake.sh",
        "required_columns": ["query_id", "repo_id", "split_name", "unseen_repository", "frozen_query_packet_sha256", "source_manifest_sha256"],
        "min_rows": 500
      },
      {
        "artifact_id": "v58-resource-rows",
        "artifact_kind": "csv",
        "validation_command": "V58C_BLIND_RESPONSE_EVIDENCE_DIR=<BLIND_RESPONSE_DIR> ./experiments/test_v58c_blind_response_evidence_intake.sh",
        "required_columns": ["blind_response_id", "blind_eval_id", "query_id", "blind_system_id", "latency_ns", "memory_peak_bytes", "resource_trace_sha256", "frozen_query_packet_sha256", "source_manifest_sha256", "context_budget", "retrieval_budget", "latency_memory_excluded_from_quality_score"],
        "min_rows": 3500,
        "per_system_min_rows": {"A": 500, "B": 500, "C": 500, "D": 500, "E": 500, "G": 500, "H": 500}
      },
      {
        "artifact_id": "v58-human-review-rows",
        "artifact_kind": "review-return",
        "validation_command": "V58D_BLIND_REVIEW_RETURN_DIR=<REVIEW_RETURN_DIR> ./experiments/test_v58d_blind_review_return_intake.sh",
        "required_columns": ["blind_response_id", "blind_eval_id", "blind_system_id", "reviewer_id", "reviewer_pool_id", "reviewer_blinded", "reviewer_independent", "conflict_disclosed", "answer_correctness", "citation_correctness", "abstain_correctness", "source_span_exactness", "unsupported_abstention_correctness", "unseen_repository_split_id", "latency_memory_excluded_from_quality_score", "policy_score", "review_decision", "review_sha256"],
        "min_rows": 7000
      },
      {
        "artifact_id": "v58-adjudication-rows",
        "artifact_kind": "review-return",
        "validation_command": "V58D_BLIND_REVIEW_RETURN_DIR=<REVIEW_RETURN_DIR> ./experiments/test_v58d_blind_review_return_intake.sh",
        "required_columns": ["blind_response_id", "blind_eval_id", "blind_system_id", "reviewer_a_id", "reviewer_b_id", "reviewer_a_decision", "reviewer_b_decision", "adjudicated_decision", "inter_rater_agree", "adjudicator_id", "adjudicator_pool_id", "adjudicator_independent", "adjudication_sha256"],
        "min_rows": 3500
      },
      {
        "artifact_id": "v58d-review-return-intake",
        "artifact_kind": "artifact-directory",
        "validation_command": "./experiments/test_v58d_blind_review_return_intake.sh",
        "required_columns": ["review_dir", "accepted_blind_review_rows", "accepted_adjudication_rows", "inter_rater_rows", "review_return_ready"],
        "min_rows": 1
      },
      {
        "artifact_id": "v58-sha256-manifest",
        "artifact_kind": "csv",
        "validation_command": "V58C_BLIND_RESPONSE_EVIDENCE_DIR=<BLIND_RESPONSE_DIR> ./experiments/test_v58c_blind_response_evidence_intake.sh",
        "required_columns": ["artifact_path", "sha256", "bytes"],
        "min_rows": 10
      }
    ]
  },
  "additionalProperties": false
}
