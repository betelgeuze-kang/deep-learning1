{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/v50_auditor_correctness.schema.json",
  "title": "v50 Auditor Correctness Contract",
  "type": "object",
  "required": ["schema_version", "policy", "replay_commands", "required_artifacts", "claim_boundaries"],
  "properties": {
    "schema_version": {"type": "string"},
    "policy": {
      "type": "object",
      "required": [
        "summary_ready_claim_present",
        "artifact_replay_ready",
        "auditor_correctness_merge_ready",
        "required_artifact_count",
        "present_required_artifact_count",
        "missing_required_artifact_count",
        "missing_required_artifact_ids",
        "implicit_public_refresh_allowed",
        "network_required_to_regenerate"
      ],
      "properties": {
        "summary_ready_claim_present": {"type": "boolean"},
        "artifact_replay_ready": {"type": "boolean"},
        "auditor_correctness_merge_ready": {"type": "boolean"},
        "required_artifact_count": {"type": "integer", "minimum": 1},
        "present_required_artifact_count": {"type": "integer", "minimum": 0},
        "missing_required_artifact_count": {"type": "integer", "minimum": 0},
        "missing_required_artifact_ids": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "implicit_public_refresh_allowed": {"type": "boolean"},
        "network_required_to_regenerate": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "replay_commands": {
      "type": "object",
      "required": ["runner", "smoke_test", "artifact_verifier"],
      "properties": {
        "runner": {"type": "string"},
        "smoke_test": {"type": "string"},
        "artifact_verifier": {"type": "string"}
      },
      "additionalProperties": false
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "artifact_kind",
          "path",
          "required_columns",
          "min_rows",
          "sha256_manifest_required",
          "required_for_merge"
        ],
        "properties": {
          "artifact_id": {"type": "string"},
          "artifact_kind": {"type": "string"},
          "path": {"type": "string"},
          "required_columns": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1
          },
          "min_rows": {"type": "integer", "minimum": 1},
          "sha256_manifest_required": {"type": "boolean"},
          "required_for_merge": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "claim_boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "allowed", "blocked"],
        "properties": {
          "claim_id": {"type": "string"},
          "allowed": {"type": "string"},
          "blocked": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "x-contract": {
    "expected_policy_static": {
      "summary_ready_claim_present": true,
      "artifact_replay_ready": false,
      "auditor_correctness_merge_ready": false,
      "implicit_public_refresh_allowed": false,
      "network_required_to_regenerate": true
    },
    "expected_required_artifacts": [
      {
        "artifact_id": "source-snapshot-rows",
        "artifact_kind": "csv",
        "required_columns": [
          "repo_id",
          "owner_repo",
          "repo_url",
          "requested_ref",
          "head_sha",
          "ref_pinned",
          "file_path",
          "artifact_path",
          "sha256",
          "bytes",
          "line_count",
          "public_repo_snapshot"
        ],
        "min_rows": 9,
        "sha256_manifest_required": true,
        "required_for_merge": true
      },
      {
        "artifact_id": "audit-case-rows",
        "artifact_kind": "csv",
        "required_columns": [
          "case_id",
          "repo_id",
          "owner_repo",
          "repo_url",
          "head_sha",
          "audit_type",
          "detector_method",
          "primary_observed",
          "secondary_observed",
          "expected_label",
          "predicted_label",
          "correct",
          "finding",
          "primary_path",
          "primary_sha256",
          "primary_line",
          "secondary_path",
          "secondary_sha256",
          "secondary_line",
          "source_spans_ready",
          "not_upstream_defect_claim"
        ],
        "min_rows": 9,
        "sha256_manifest_required": true,
        "required_for_merge": true
      },
      {
        "artifact_id": "source-span-rows",
        "artifact_kind": "csv",
        "required_columns": [
          "case_id",
          "repo_id",
          "kind",
          "path",
          "sha256",
          "line",
          "text"
        ],
        "min_rows": 18,
        "sha256_manifest_required": true,
        "required_for_merge": true
      },
      {
        "artifact_id": "guard-negative-rows",
        "artifact_kind": "csv",
        "required_columns": [
          "negative_case_id",
          "guard",
          "expected_block",
          "blocked",
          "wrong_answer_guard_pass",
          "citation_accuracy_pass",
          "abstain_behavior_pass",
          "reason"
        ],
        "min_rows": 3,
        "sha256_manifest_required": true,
        "required_for_merge": true
      },
      {
        "artifact_id": "commercial-return-query-set",
        "artifact_kind": "csv",
        "required_columns": [
          "query_id",
          "question",
          "expected_behavior",
          "source_path",
          "source_sha256",
          "source_line"
        ],
        "min_rows": 9,
        "sha256_manifest_required": true,
        "required_for_merge": true
      },
      {
        "artifact_id": "commercial-return-poc-results",
        "artifact_kind": "csv",
        "required_columns": [
          "query_id",
          "answer",
          "citation_path",
          "citation_sha256",
          "citation_line",
          "citation_text",
          "secondary_citation_path",
          "secondary_citation_sha256",
          "secondary_citation_line",
          "secondary_citation_text",
          "wrong_answer_guard_pass",
          "citation_accuracy_pass",
          "abstain_behavior_pass",
          "query_to_evidence_latency_ready",
          "latency_ms",
          "route_memory_lineage_bound",
          "mmap_or_exact_span_bound",
          "audit_trail_bound"
        ],
        "min_rows": 9,
        "sha256_manifest_required": true,
        "required_for_merge": true
      },
      {
        "artifact_id": "commercial-return-audit-trail",
        "artifact_kind": "csv",
        "required_columns": [
          "event_id",
          "query_id",
          "event",
          "repo_id",
          "verifier_decision",
          "status"
        ],
        "min_rows": 9,
        "sha256_manifest_required": true,
        "required_for_merge": true
      },
      {
        "artifact_id": "sha256-manifest",
        "artifact_kind": "csv",
        "required_columns": [
          "path",
          "sha256",
          "bytes"
        ],
        "min_rows": 7,
        "sha256_manifest_required": false,
        "required_for_merge": true
      }
    ],
    "expected_summary_when_supplied": {
      "v50_public_repo_auditor_3repo_ready": "1",
      "repo_count": "3",
      "repo_refs_pinned": "1",
      "audit_case_rows": "9",
      "audit_type_count": "3",
      "guard_negative_rows": "3",
      "guard_negative_block_rows": "3",
      "source_span_rows": "18",
      "wrong_answer_guard_pass_rows": "9",
      "citation_accuracy_pass_rows": "9",
      "audit_trail_bound_rows": "9",
      "human_review_completed": "0",
      "real_release_package_ready": "0"
    },
    "expected_decision_gates_when_supplied": {
      "pass": [
        "v50-public-repo-auditor-3repo",
        "public-repo-count",
        "pinned-repo-refs",
        "source-snapshot",
        "doc-code-conflict",
        "deprecated-usage",
        "config-mismatch",
        "source-citation-audit-trail",
        "guard-negative-controls",
        "v18-intake"
      ],
      "blocked": {
        "real-release-package": "blocked"
      }
    }
  },
  "additionalProperties": false
}
