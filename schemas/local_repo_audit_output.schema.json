{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_output.schema.json",
  "title": "Local repo audit output manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "tool_source_sha256",
    "verifier_source_sha256",
    "schema_sha256s",
    "generated_at_utc",
    "target_repo",
    "source_scope",
    "changed_files_from",
    "changed_files_from_sha256",
    "changed_file_rows",
    "namespace",
    "real_benchmark_namespace_confirmed",
    "fixture_result_promoted",
    "real_evidence_claimed",
    "source_file_count",
    "finding_rows",
    "suppression_rows",
    "atomic_publish",
    "output_dir_destroyed",
    "output_dir_overwritten",
    "publish_mode",
    "run_id",
    "bundle_run_dir",
    "latest_pointer",
    "cache_key",
    "plugin_registry_sha256",
    "suppression_file_sha256",
    "baseline_output",
    "baseline_output_sha256",
    "claim_boundary",
    "release_ready",
    "public_comparison_claim_ready",
    "real_model_execution_ready",
    "emit_diagnostics_requested"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit_output.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "tool_source_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "verifier_source_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "schema_sha256s": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
    },
    "generated_at_utc": {"const": "1970-01-01T00:00:00+00:00"},
    "target_repo": {"type": "string", "minLength": 1},
    "source_scope": {"type": "string", "enum": ["tracked", "changed-files"]},
    "changed_files_from": {"type": "string"},
    "changed_files_from_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "changed_file_rows": {"type": "integer", "minimum": 0},
    "namespace": {"enum": ["fixture", "synthetic", "real_benchmark"]},
    "real_benchmark_namespace_confirmed": {"type": "integer", "enum": [0, 1]},
    "fixture_result_promoted": {"const": 0},
    "real_evidence_claimed": {"const": 0},
    "source_file_count": {"type": "integer", "minimum": 1},
    "finding_rows": {"type": "integer", "minimum": 1},
    "suppression_rows": {"type": "integer", "minimum": 0},
    "atomic_publish": {"const": 1},
    "output_dir_destroyed": {"const": 0},
    "output_dir_overwritten": {"const": 0},
    "publish_mode": {"const": "versioned-run-dir-with-latest-pointer"},
    "run_id": {"type": "string", "pattern": "^run-[0-9a-f]{16}$"},
    "bundle_run_dir": {"type": "string", "minLength": 1},
    "latest_pointer": {"type": "string", "minLength": 1},
    "cache_key": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "plugin_registry_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "suppression_file_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "baseline_output": {"type": "string"},
    "baseline_output_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "claim_boundary": {"const": "alpha-local-code-doc-audit-only"},
    "release_ready": {"const": 0},
    "public_comparison_claim_ready": {"const": 0},
    "real_model_execution_ready": {"const": 0},
    "emit_diagnostics_requested": {"type": "integer", "enum": [0, 1]}
  }
}
