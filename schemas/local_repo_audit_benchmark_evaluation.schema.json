{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_benchmark_evaluation.schema.json",
  "title": "Local repo audit benchmark evaluation rows",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "claim_boundary",
    "release_ready",
    "public_comparison_claim_ready",
    "real_model_execution_ready",
    "metrics",
    "confusion_rows",
    "abstain_correctness_rows",
    "citation_validity_detail_rows",
    "confusion",
    "abstain_correctness",
    "citation_validity"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit_benchmark_evaluation.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "claim_boundary": {"const": "alpha-local-code-doc-audit-only"},
    "release_ready": {"const": 0},
    "public_comparison_claim_ready": {"const": 0},
    "real_model_execution_ready": {"const": 0},
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "human_label_rows",
        "tp",
        "fp",
        "fn",
        "p0_p1_label_rows",
        "p0_p1_tp",
        "p0_p1_fp",
        "p0_p1_fn",
        "precision",
        "recall",
        "p0_p1_precision",
        "abstain_checked",
        "abstain_correct",
        "citation_validity_rows",
        "citation_validity_pass_rows",
        "label_citation_expectation_rows",
        "label_citation_expectation_met_rows",
        "overall_precision_requirement_met",
        "p0_p1_precision_requirement_met",
        "citation_validity_requirement_met",
        "label_citation_expectation_requirement_met"
      ],
      "properties": {
        "human_label_rows": {"type": "integer", "minimum": 0},
        "tp": {"type": "integer", "minimum": 0},
        "fp": {"type": "integer", "minimum": 0},
        "fn": {"type": "integer", "minimum": 0},
        "p0_p1_label_rows": {"type": "integer", "minimum": 0},
        "p0_p1_tp": {"type": "integer", "minimum": 0},
        "p0_p1_fp": {"type": "integer", "minimum": 0},
        "p0_p1_fn": {"type": "integer", "minimum": 0},
        "precision": {"type": "string", "pattern": "^[0-9]+\\.[0-9]{6}$"},
        "recall": {"type": "string", "pattern": "^[0-9]+\\.[0-9]{6}$"},
        "p0_p1_precision": {"type": "string", "pattern": "^[0-9]+\\.[0-9]{6}$"},
        "abstain_checked": {"type": "integer", "minimum": 0},
        "abstain_correct": {"type": "integer", "minimum": 0},
        "citation_validity_rows": {"type": "integer", "minimum": 0},
        "citation_validity_pass_rows": {"type": "integer", "minimum": 0},
        "label_citation_expectation_rows": {"type": "integer", "minimum": 0},
        "label_citation_expectation_met_rows": {"type": "integer", "minimum": 0},
        "overall_precision_requirement_met": {"type": "integer", "enum": [0, 1]},
        "p0_p1_precision_requirement_met": {"type": "integer", "enum": [0, 1]},
        "citation_validity_requirement_met": {"type": "integer", "enum": [0, 1]},
        "label_citation_expectation_requirement_met": {"type": "integer", "enum": [0, 1]}
      }
    },
    "confusion_rows": {"type": "integer", "minimum": 0},
    "abstain_correctness_rows": {"type": "integer", "minimum": 0},
    "citation_validity_detail_rows": {"type": "integer", "minimum": 0},
    "confusion": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "row_type",
          "label_id",
          "plugin_id",
          "rule_id",
          "file_path",
          "expected_line_start",
          "expected_line_end",
          "expected_span_sha256",
          "expected",
          "priority",
          "matched_finding_id",
          "citation_expectation_supplied",
          "matched_citation_id",
          "citation_expectation_met",
          "outcome",
          "tp",
          "fp",
          "fn",
          "tn"
        ],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "row_type": {"type": "string", "enum": ["human_label", "unmatched_finding"]},
          "label_id": {"type": "string"},
          "plugin_id": {"type": "string"},
          "rule_id": {"type": "string"},
          "file_path": {"type": "string"},
          "expected_line_start": {"type": "string", "pattern": "^$|^[0-9]+$"},
          "expected_line_end": {"type": "string", "pattern": "^$|^[0-9]+$"},
          "expected_span_sha256": {"type": "string", "pattern": "^$|^sha256:[0-9a-f]{64}$"},
          "expected": {"type": "string", "enum": ["present", "absent"]},
          "priority": {"type": "string"},
          "matched_finding_id": {"type": "string"},
          "citation_expectation_supplied": {"type": "string", "enum": ["0", "1"]},
          "matched_citation_id": {"type": "string"},
          "citation_expectation_met": {"type": "string", "enum": ["", "0", "1"]},
          "outcome": {"type": "string", "enum": ["TP", "FP", "FN", "TN"]},
          "tp": {"type": "string", "enum": ["0", "1"]},
          "fp": {"type": "string", "enum": ["0", "1"]},
          "fn": {"type": "string", "enum": ["0", "1"]},
          "tn": {"type": "string", "enum": ["0", "1"]}
        }
      }
    },
    "abstain_correctness": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "label_id",
          "plugin_id",
          "rule_id",
          "file_path",
          "expected",
          "expected_abstain",
          "matched_finding_id",
          "actual_abstain",
          "outcome",
          "abstain_correct"
        ],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "label_id": {"type": "string", "minLength": 1},
          "plugin_id": {"type": "string"},
          "rule_id": {"type": "string"},
          "file_path": {"type": "string"},
          "expected": {"type": "string", "enum": ["present", "absent"]},
          "expected_abstain": {"type": "string", "enum": ["0", "1"]},
          "matched_finding_id": {"type": "string"},
          "actual_abstain": {"type": "string", "enum": ["0", "1"]},
          "outcome": {"type": "string", "enum": ["TP", "FP", "FN", "TN"]},
          "abstain_correct": {"type": "string", "enum": ["0", "1"]}
        }
      }
    },
    "citation_validity": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "finding_id",
          "citation_id",
          "file_path",
          "line_start",
          "line_end",
          "file_exists",
          "file_sha256_valid",
          "source_manifest_sha256_valid",
          "line_bounds_valid",
          "span_sha256_valid",
          "span_preview_valid",
          "citation_valid",
          "invalid_reasons"
        ],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "finding_id": {"type": "string", "minLength": 1},
          "citation_id": {"type": "string", "minLength": 1},
          "file_path": {"type": "string", "minLength": 1},
          "line_start": {"type": "string", "pattern": "^[0-9]+$"},
          "line_end": {"type": "string", "pattern": "^[0-9]+$"},
          "file_exists": {"type": "string", "enum": ["0", "1"]},
          "file_sha256_valid": {"type": "string", "enum": ["0", "1"]},
          "source_manifest_sha256_valid": {"type": "string", "enum": ["0", "1"]},
          "line_bounds_valid": {"type": "string", "enum": ["0", "1"]},
          "span_sha256_valid": {"type": "string", "enum": ["0", "1"]},
          "span_preview_valid": {"type": "string", "enum": ["0", "1"]},
          "citation_valid": {"type": "string", "enum": ["0", "1"]},
          "invalid_reasons": {"type": "string"}
        }
      }
    }
  }
}
