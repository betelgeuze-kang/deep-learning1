{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_benchmark_manifest.schema.json",
  "title": "Local repo audit benchmark manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "claim_boundary",
    "benchmark_runner_source_sha256",
    "audit_entrypoint_source_sha256",
    "local_audit_verifier_source_sha256",
    "labels_input",
    "labels_input_sha256",
    "label_source_kind",
    "label_intake_output",
    "label_intake_manifest_sha256",
    "label_intake_sha256sums_sha256",
    "feedback_input",
    "feedback_input_sha256",
    "mode",
    "namespace",
    "rerun_check_requested",
    "max_files",
    "max_total_bytes",
    "max_file_bytes",
    "max_findings",
    "case_rows",
    "human_label_rows",
    "maintainer_feedback_rows",
    "repo_snapshot_rows",
    "repo_snapshot_locked_rows",
    "repo_snapshot_requirement_met",
    "case_ids",
    "case_run_manifest_sha256s",
    "case_runs_manifest_sha256",
    "artifact_sha256s",
    "overall_precision_threshold",
    "p0_p1_precision_threshold",
    "product_readiness_calculated_from_real_labels",
    "design_partner_beta_candidate_ready",
    "synthetic_smoke_promoted_to_real_benchmark",
    "release_ready",
    "public_comparison_claim_ready",
    "real_model_execution_ready"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit_benchmark_manifest.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "claim_boundary": {"const": "alpha-local-code-doc-audit-only"},
    "benchmark_runner_source_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "audit_entrypoint_source_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "local_audit_verifier_source_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "labels_input": {"type": "string", "minLength": 1},
    "labels_input_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "label_source_kind": {"type": "string", "enum": ["direct_labels", "label_intake"]},
    "label_intake_output": {"type": "string"},
    "label_intake_manifest_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "label_intake_sha256sums_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "feedback_input": {"type": "string"},
    "feedback_input_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "mode": {"type": "string", "enum": ["quick", "full"]},
    "namespace": {"type": "string", "enum": ["fixture", "synthetic", "real_benchmark"]},
    "rerun_check_requested": {"type": "integer", "enum": [0, 1]},
    "max_files": {"type": "integer", "minimum": 1},
    "max_total_bytes": {"type": "integer", "minimum": 1},
    "max_file_bytes": {"type": "integer", "minimum": 1},
    "max_findings": {"type": "integer", "minimum": 1},
    "case_rows": {"type": "integer", "minimum": 1},
    "human_label_rows": {"type": "integer", "minimum": 0},
    "maintainer_feedback_rows": {"type": "integer", "minimum": 0},
    "repo_snapshot_rows": {"type": "integer", "minimum": 0},
    "repo_snapshot_locked_rows": {"type": "integer", "minimum": 0},
    "repo_snapshot_requirement_met": {"type": "integer", "enum": [0, 1]},
    "case_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,127}$"},
      "minItems": 1
    },
    "case_run_manifest_sha256s": {
      "type": "object",
      "additionalProperties": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
    },
    "case_runs_manifest_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "artifact_sha256s": {
      "type": "object",
      "additionalProperties": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
    },
    "overall_precision_threshold": {"const": "0.800000"},
    "p0_p1_precision_threshold": {"const": "0.900000"},
    "product_readiness_calculated_from_real_labels": {"type": "integer", "enum": [0, 1]},
    "design_partner_beta_candidate_ready": {"type": "integer", "enum": [0, 1]},
    "synthetic_smoke_promoted_to_real_benchmark": {"const": 0},
    "release_ready": {"const": 0},
    "public_comparison_claim_ready": {"const": 0},
    "real_model_execution_ready": {"const": 0}
  }
}
