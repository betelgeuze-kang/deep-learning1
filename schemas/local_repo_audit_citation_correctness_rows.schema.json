{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "claim_boundary",
    "release_ready",
    "public_comparison_claim_ready",
    "real_model_execution_ready",
    "citation_correctness_rows",
    "manual_citation_review_required",
    "rows"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit_citation_correctness_rows.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "claim_boundary": {"const": "alpha-local-code-doc-audit-only"},
    "release_ready": {"const": 0},
    "public_comparison_claim_ready": {"const": 0},
    "real_model_execution_ready": {"const": 0},
    "citation_correctness_rows": {"type": "integer", "minimum": 1},
    "manual_citation_review_required": {"const": 1},
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "citation_count",
          "citation_bound",
          "citation_correctness_label",
          "manual_citation_review_required"
        ],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "citation_count": {"type": "integer", "minimum": 0},
          "citation_bound": {"type": "integer", "enum": [0, 1]},
          "citation_correctness_label": {"const": "source_bound_unreviewed"},
          "manual_citation_review_required": {"const": 1}
        }
      }
    }
  }
}
