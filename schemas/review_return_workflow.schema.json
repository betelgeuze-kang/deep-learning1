  "required": ["schema_version", "policy", "requirements"],
  "properties": {
    "schema_version": {"type": "string"},
    "policy": {
      "type": "object",
      "required": [
        "workflow_contract_ready",
        "human_review_ready",
        "adjudication_ready",
        "operator_input_files_ready",
        "actual_generation_ready",
        "production_latency_claim_ready",
        "near_frontier_claim_ready",
        "quality_comparison_claim_ready",
        "public_comparison_claim_ready",
        "release_ready",
        "fixture_can_close_real_return",
        "accepted_human_review_rows",
        "accepted_adjudication_rows",
        "accepted_operator_return_rows"
      ],
      "properties": {
        "workflow_contract_ready": {"type": "boolean"},
        "human_review_ready": {"type": "boolean"},
        "adjudication_ready": {"type": "boolean"},
        "operator_input_files_ready": {"type": "boolean"},
        "actual_generation_ready": {"type": "boolean"},
        "production_latency_claim_ready": {"type": "boolean"},
        "near_frontier_claim_ready": {"type": "boolean"},
        "quality_comparison_claim_ready": {"type": "boolean"},
        "public_comparison_claim_ready": {"type": "boolean"},
        "release_ready": {"type": "boolean"},
        "fixture_can_close_real_return": {"type": "boolean"},
