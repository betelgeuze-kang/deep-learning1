        "accepted_adjudication_rows": {"type": "integer", "const": 0},
        "accepted_operator_return_rows": {"type": "integer", "const": 0}
      },
      "additionalProperties": false
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "requirement_id",
          "required_evidence",
          "current_status",
          "evidence_path",
          "claim_boundary",
          "summary_checks"
        ],
        "properties": {
          "requirement_id": {"type": "string"},
          "required_evidence": {"type": "string"},
          "current_status": {"type": "string", "enum": ["pass"]},
          "evidence_path": {"type": "string"},
          "claim_boundary": {"type": "string"},
          "summary_checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["summary_id", "field", "expected"],
              "properties": {
                "summary_id": {"type": "string", "enum": ["v53s", "v58d", "v61af", "v61hv"]},
                "field": {"type": "string"},
                "expected": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
