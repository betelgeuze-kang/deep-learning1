{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_resource_envelope.schema.json",
  "title": "Local repo audit resource envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resource_envelope_ready",
    "tool_version",
    "source_files_scanned",
    "max_queries",
    "mode",
    "namespace",
    "external_network_used",
    "raw_prompt_context_bytes",
    "latency_ms",
    "wrong_answer_guard_rows",
    "claim_boundary_ready"
  ],
  "properties": {
    "resource_envelope_ready": {"const": 1},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "source_files_scanned": {"type": "integer", "minimum": 1},
    "max_queries": {"type": "integer", "minimum": 1},
    "mode": {"type": "string", "enum": ["quick", "full"]},
    "namespace": {"type": "string", "enum": ["fixture", "synthetic", "real_benchmark"]},
    "external_network_used": {"const": 0},
    "raw_prompt_context_bytes": {"const": 0},
    "latency_ms": {"const": 0},
    "wrong_answer_guard_rows": {"type": "integer", "minimum": 1},
    "claim_boundary_ready": {"const": 1}
  }
}
