{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_findings.schema.json",
  "title": "Local repo audit standard JSON findings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "claim_boundary",
    "release_ready",
    "public_comparison_claim_ready",
    "real_model_execution_ready",
    "findings",
    "citation_spans"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit_findings.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "claim_boundary": {"const": "alpha-local-code-doc-audit-only"},
    "release_ready": {"const": 0},
    "public_comparison_claim_ready": {"const": 0},
    "real_model_execution_ready": {"const": 0},
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "audit_type",
          "plugin_id",
          "plugin_rule_ids",
          "confidence",
          "language",
          "question",
          "answer",
          "severity",
          "grounded",
          "abstain",
          "unsupported_claim",
          "suppressed",
          "suppression_ids",
          "citations",
          "citation_sha256s",
          "route_memory_lineage",
          "raw_prompt_context_bytes",
          "oracle_prediction_used",
          "raw_input_extractor_used"
        ],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "audit_type": {"type": "string", "minLength": 1},
          "plugin_id": {"type": "string", "minLength": 1},
          "plugin_rule_ids": {"type": "string", "minLength": 1},
          "confidence": {"type": "string", "minLength": 1},
          "language": {"type": "string", "minLength": 1},
          "question": {"type": "string"},
          "answer": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "enum": ["info", "low", "medium", "high"]},
          "grounded": {"type": "integer", "enum": [0, 1]},
          "abstain": {"type": "integer", "enum": [0, 1]},
          "unsupported_claim": {"type": "integer", "enum": [0, 1]},
          "suppressed": {"type": "integer", "enum": [0, 1]},
          "suppression_ids": {"type": "string"},
          "citations": {"type": "string"},
          "citation_sha256s": {"type": "string"},
          "route_memory_lineage": {"type": "integer", "enum": [0, 1]},
          "raw_prompt_context_bytes": {"type": "integer", "minimum": 0},
          "oracle_prediction_used": {"type": "integer", "enum": [0, 1]},
          "raw_input_extractor_used": {"type": "integer", "enum": [0, 1]}
        }
      }
    },
    "citation_spans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "citation_id",
          "file_path",
          "line_start",
          "line_end",
          "sha256",
          "span_sha256",
          "span_text_preview",
          "mmap_value_byte_read"
        ],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "citation_id": {"type": "string", "minLength": 1},
          "file_path": {"type": "string", "minLength": 1},
          "line_start": {"type": "integer", "minimum": 1},
          "line_end": {"type": "integer", "minimum": 1},
          "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "span_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
          "span_text_preview": {"type": "string"},
          "mmap_value_byte_read": {"type": "integer", "enum": [0, 1]}
        }
      }
    }
  }
}
