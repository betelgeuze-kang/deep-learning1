{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_first_report_smoke.schema.json",
  "title": "Local repo audit first report smoke receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "claim_boundary",
    "max_wall_ms",
    "total_wall_ms",
    "install_exit_code",
    "install_wall_ms",
    "audit_exit_code",
    "audit_wall_ms",
    "verify_exit_code",
    "verify_wall_ms",
    "first_report_success",
    "within_time_budget",
    "audit_output",
    "report_path",
    "audit_manifest_sha256",
    "audit_summary_sha256",
    "audit_report_sha256",
    "cache_key",
    "run_id",
    "release_ready",
    "public_comparison_claim_ready",
    "real_model_execution_ready",
    "external_network_used",
    "fixture_only",
    "design_partner_beta_candidate_ready",
    "error"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit_first_report_smoke.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "claim_boundary": {"const": "alpha-local-code-doc-audit-only"},
    "max_wall_ms": {"type": "integer", "minimum": 1},
    "total_wall_ms": {"type": "integer", "minimum": 1},
    "install_exit_code": {"type": "integer", "minimum": 0},
    "install_wall_ms": {"type": "integer", "minimum": 1},
    "audit_exit_code": {"type": "integer", "minimum": 0},
    "audit_wall_ms": {"type": "integer", "minimum": 0},
    "verify_exit_code": {"type": "integer", "minimum": 0},
    "verify_wall_ms": {"type": "integer", "minimum": 0},
    "first_report_success": {"type": "integer", "enum": [0, 1]},
    "within_time_budget": {"type": "integer", "enum": [0, 1]},
    "audit_output": {"type": "string"},
    "report_path": {"type": "string"},
    "audit_manifest_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "audit_summary_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "audit_report_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "cache_key": {"type": "string"},
    "run_id": {"type": "string"},
    "release_ready": {"const": 0},
    "public_comparison_claim_ready": {"const": 0},
    "real_model_execution_ready": {"const": 0},
    "external_network_used": {"const": 0},
    "fixture_only": {"const": 1},
    "design_partner_beta_candidate_ready": {"const": 0},
    "error": {"type": "string"}
  }
}
