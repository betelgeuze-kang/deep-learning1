{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/pr_split.schema.json",
  "title": "Draft PR Split Contract",
  "type": "object",
  "required": [
    "schema_version",
    "draft_pr",
    "split_required",
    "recommended_title",
    "recommended_body",
    "merge_gate_policy",
    "branch_integration_policy",
    "slices"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["pr_split.v1"]},
    "draft_pr": {"type": "string", "enum": ["PR #2"]},
    "split_required": {"type": "boolean", "enum": [true]},
    "recommended_title": {"type": "string", "minLength": 1},
    "recommended_body": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "merge_gate_policy": {
      "type": "object",
      "required": ["forbid_tests_only", "required_gates"],
      "properties": {
        "forbid_tests_only": {"type": "boolean", "enum": [true]},
        "required_gates": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["claim-boundary", "replay-artifact", "blocker-false-positive"]
          }
        }
      },
      "additionalProperties": false
    },
    "branch_integration_policy": {
      "type": "object",
      "required": [
        "source_of_truth_ref",
        "main_source_of_truth",
        "development_rebase_required",
        "forbid_giant_branch_merge",
        "max_ahead_commits_per_pr",
        "max_behind_commits_per_pr",
        "readiness_increase_requires_artifact",
        "required_pr_groups",
        "blocked_integration_patterns",
        "current_development_branch_risk"
      ],
      "properties": {
        "source_of_truth_ref": {"type": "string", "enum": ["main"]},
        "main_source_of_truth": {"type": "boolean", "enum": [true]},
        "development_rebase_required": {"type": "boolean", "enum": [true]},
        "forbid_giant_branch_merge": {"type": "boolean", "enum": [true]},
        "max_ahead_commits_per_pr": {"type": "integer", "minimum": 1, "maximum": 80},
        "max_behind_commits_per_pr": {"type": "integer", "enum": [0]},
        "readiness_increase_requires_artifact": {"type": "boolean", "enum": [true]},
        "required_pr_groups": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "prefixItems": [
            {"type": "string", "enum": ["product"]},
            {"type": "string", "enum": ["v52"]},
            {"type": "string", "enum": ["v53"]},
            {"type": "string", "enum": ["v54"]},
            {"type": "string", "enum": ["v58"]},
            {"type": "string", "enum": ["v61"]}
          ]
        },
        "blocked_integration_patterns": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "current_development_branch_risk": {
          "type": "object",
          "required": ["branch", "ahead_commits", "behind_commits", "status"],
          "properties": {
            "branch": {"type": "string", "enum": ["codex/route-memory-local-energy-policy"]},
            "ahead_commits": {"type": "integer", "minimum": 400},
            "behind_commits": {"type": "integer", "minimum": 1},
            "status": {"type": "string", "enum": ["blocked-large-branch"]}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "slices": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "items": {
        "type": "object",
        "required": [
          "slice_id",
          "scope",
          "required_artifacts",
          "merge_gates",
          "claim_boundary",
          "verification_commands",
          "current_status"
        ],
        "properties": {
          "slice_id": {
            "type": "string",
            "enum": [
              "docs/v1-roadmap",
              "v50-auditor-correctness",
              "v52-baseline-registry-contract",
              "v53-public-repo-source-manifest",
              "v53-query-instantiation-1000",
              "v53-system-a-b-g-h-measured",
              "v54-routehint-generation-contract",
              "v56-ruler-longbench-expanded",
              "v58-blind-eval-contract",
              "v59-one-command-demo",
              "v61-ssd-moe-runtime-roadmap",
              "operator-review-return-workflow",
              "docs-readme-pr2-cleanup"
            ]
          },
          "scope": {"type": "string", "minLength": 1},
          "required_artifacts": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "merge_gates": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": ["claim-boundary", "replay-artifact", "blocker-false-positive"]
            }
          },
          "claim_boundary": {
            "type": "object",
            "required": ["allowed", "blocked", "evidence_path"],
            "properties": {
              "allowed": {"type": "string", "minLength": 1},
              "blocked": {"type": "string", "minLength": 1},
              "evidence_path": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "verification_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "not": {
                "enum": ["test", "tests", "test pass", "tests pass", "ci green"]
              }
            }
          },
          "current_status": {
            "type": "string",
            "enum": [
              "ready-for-review",
              "blocked-artifact-replay-missing",
              "blocked-missing-replay-artifact",
              "ready-for-contract-review-real-eval-blocked",
              "pm-foundation-ready-full-demo-blocked",
              "ready-for-rd-review",
              "ready-for-workflow-review-real-return-blocked"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
