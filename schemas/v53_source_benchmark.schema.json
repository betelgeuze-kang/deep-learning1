{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/v53_source_benchmark.schema.json",
  "title": "v53 Source-Bound Benchmark Freeze Contract",
  "type": "object",
  "required": ["schema_version", "policy", "requirements"],
  "properties": {
    "schema_version": {"type": "string"},
    "policy": {
      "type": "object",
      "required": [
        "benchmark_id",
        "machine_foundation_freeze_ready",
        "human_review_ready",
        "public_comparison_claim_ready",
        "release_ready"
      ],
      "properties": {
        "benchmark_id": {"type": "string"},
        "machine_foundation_freeze_ready": {"type": "boolean"},
        "human_review_ready": {"type": "boolean"},
        "public_comparison_claim_ready": {"type": "boolean"},
        "release_ready": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "requirement_id",
          "required_evidence",
          "current_status",
          "evidence_path",
          "claim_boundary",
          "summary_checks"
        ],
        "properties": {
          "requirement_id": {"type": "string"},
          "required_evidence": {"type": "string"},
          "current_status": {"type": "string", "enum": ["pass"]},
          "evidence_path": {"type": "string"},
          "claim_boundary": {"type": "string"},
          "summary_checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["summary_id", "field", "expected"],
              "properties": {
                "summary_id": {"type": "string", "enum": ["v53i", "v53t", "v53ap", "v53aq"]},
                "field": {"type": "string"},
                "expected": {"type": "string"}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
