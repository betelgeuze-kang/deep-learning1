{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_sarif.schema.json",
  "title": "Local repo audit SARIF output",
  "type": "object",
  "additionalProperties": true,
  "required": ["$schema", "version", "runs"],
  "properties": {
    "$schema": {"const": "https://json.schemastore.org/sarif-2.1.0.json"},
    "version": {"const": "2.1.0"},
    "runs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": ["tool", "results", "properties"],
        "properties": {
          "tool": {
            "type": "object",
            "required": ["driver"],
            "properties": {
              "driver": {
                "type": "object",
                "required": ["name", "semanticVersion", "rules"],
                "properties": {
                  "name": {"const": "audit-my-repo"},
                  "semanticVersion": {"const": "audit_my_repo_alpha.v1"},
                  "rules": {"type": "array"}
                }
              }
            }
          },
          "results": {"type": "array", "minItems": 1},
          "properties": {
            "type": "object",
            "required": [
              "schema_version",
              "claim_boundary",
              "release_ready",
              "public_comparison_claim_ready",
              "real_model_execution_ready"
            ],
            "properties": {
              "schema_version": {"const": "local_repo_audit_sarif.v1"},
              "claim_boundary": {"const": "alpha-local-code-doc-audit-only"},
              "release_ready": {"const": 0},
              "public_comparison_claim_ready": {"const": 0},
              "real_model_execution_ready": {"const": 0}
            }
          }
        }
      }
    }
  }
}
