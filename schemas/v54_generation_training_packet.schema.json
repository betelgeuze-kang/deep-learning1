{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/v54_generation_training_packet.schema.json",
  "title": "v54 Generation Training Packet Config",
  "description": "Schema for generation_config.json and checkpoint_manifest.json in a v54 training/heldout packet.",
  "definitions": {
    "generation_config": {
      "type": "object",
      "required": ["generator_id", "seed", "free_running_in_eval", "raw_source_span_in_prompt", "source_locator_leakage"],
      "properties": {
        "generator_id": {"type": "string", "minLength": 1},
        "vocab_size": {},
        "embed_dim": {},
        "hidden_dim": {},
        "context_dim": {},
        "seed": {"type": "integer"},
        "query_source": {"type": "string"},
        "teacher_forcing_in_training": {"type": "boolean"},
        "free_running_in_eval": {"const": true},
        "raw_source_span_in_prompt": {"const": false},
        "source_locator_leakage": {"const": false}
      },
      "additionalProperties": true
    },
    "checkpoint_manifest": {
      "type": "object",
      "required": ["checkpoint_sha256", "config_sha256", "trained_on_split"],
      "properties": {
        "checkpoint_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "config_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "trained_on_split": {"type": "string", "enum": ["train"]},
        "calibrated_on_split": {"type": "string", "enum": ["calibration"]}
      },
      "additionalProperties": true
    }
  }
}
