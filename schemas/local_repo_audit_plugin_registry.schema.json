{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.discrete-local-energy/schemas/local_repo_audit_plugin_registry.schema.json",
  "title": "Local repo audit plugin registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_version",
    "plugins"
  ],
  "properties": {
    "schema_version": {"const": "local_repo_audit.v1"},
    "tool_version": {"const": "audit_my_repo_alpha.v1"},
    "plugins": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "plugin_id",
          "audit_type",
          "language",
          "module",
          "source_path",
          "source_sha256"
        ],
        "properties": {
          "plugin_id": {
            "type": "string",
            "enum": [
              "doc_code_identity",
              "deprecated_api",
              "config_consistency",
              "unsupported_claim",
              "missing_evidence",
              "user_question"
            ]
          },
          "audit_type": {
            "type": "string",
            "enum": [
              "doc_code_identity",
              "deprecated_api",
              "config_consistency",
              "unsupported_claim",
              "missing_evidence",
              "user_question"
            ]
          },
          "language": {"type": "string", "enum": ["generic", "multi"]},
          "module": {
            "type": "string",
            "enum": [
              "auditor_plugin_doc_code_identity",
              "auditor_plugin_deprecated_api",
              "auditor_plugin_config_consistency",
              "auditor_plugin_unsupported_claim",
              "auditor_plugin_missing_evidence",
              "auditor_plugin_user_question"
            ]
          },
          "source_path": {
            "type": "string",
            "enum": [
              "scripts/auditor_plugin_doc_code_identity.py",
              "scripts/auditor_plugin_deprecated_api.py",
              "scripts/auditor_plugin_config_consistency.py",
              "scripts/auditor_plugin_unsupported_claim.py",
              "scripts/auditor_plugin_missing_evidence.py",
              "scripts/auditor_plugin_user_question.py"
            ]
          },
          "source_sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
